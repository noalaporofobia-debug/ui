-- Theme management
local function applyTheme(t, localTheme)
    local target = localTheme or Theme
    if type(t) == "string" and ThemePresets[t] then
        for k,v in pairs(ThemePresets[t]) do target[k] = v end
    elseif type(t) == "table" then
        for k,v in pairs(t) do target[k] = v end
    end
    if not localTheme then
        NovaUI:TriggerHook("OnThemeChanged", Theme)
        for _, win in ipairs(Windows) do win:Redraw() end
    end
end

-- Utility
local function Create(class, props)
    local obj = Instance.new(class)
    for k,v in pairs(props or {}) do
        if k == "Corner" then local c = Instance.new("UICorner"); c.CornerRadius = v; c.Parent = obj
        elseif k == "Stroke" then local s = Instance.new("UIStroke"); s.Color = v.Color or Theme.Border; s.Thickness = v.Thickness or 1; if v.Transparency then s.Transparency = v.Transparency end; s.Parent = obj
        elseif k == "Gradient" then local g = Instance.new("UIGradient"); for k2,v2 in pairs(v) do g[k2]=v2 end; g.Parent = obj
        elseif k == "Padding" then local p = Instance.new("UIPadding"); for side,amt in pairs(v) do p[side]=UDim.new(0,amt) end; p.Parent = obj
        elseif k == "List" then local l = Instance.new("UIListLayout"); l.SortOrder = Enum.SortOrder.LayoutOrder; l.Padding = UDim.new(0, v.Padding or Theme.Padding); l.FillDirection = v.FillDirection or Enum.FillDirection.Vertical; l.Parent = obj
        else obj[k] = v end
    end
    return obj
end

local function Spring(obj, props, duration, speed, damping)
    if Theme.AnimSpeed <= 0 then for k,v in pairs(props) do obj[k] = v end; return nil end
    local info = TweenInfo.new(duration or Theme.AnimSpeed, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out, 0, false, speed or 0.8, damping or 0.7)
    local t = Tween:Create(obj, info, props); t:Play(); return t
end

local function TweenObj(obj, props, duration)
    if Theme.AnimSpeed <= 0 then for k,v in pairs(props) do obj[k] = v end; return nil end
    local info = TweenInfo.new(duration or Theme.AnimSpeed, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
    local t = Tween:Create(obj, info, props); t:Play(); return t
end

local function PlaySound(id)
    if not Theme.SoundEnabled then return end
    local sound = Instance.new("Sound")
    sound.SoundId = id or "rbxassetid://9116338653"
    sound.Volume = 0.5
    sound.Parent = CoreGui
    sound:Play()
    task.delay(0.5, function() sound:Destroy() end)
end

local function indexOf(tbl, value) for i,v in ipairs(tbl) do if v==value then return i end end; return nil end

