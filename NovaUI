local Slider = {}
function Slider:Create(parent, opts)
    local internal = opts.internal or false
    local f = Create("Frame", {Parent=parent, BackgroundTransparency=1, Size=UDim2.new(1,0,0,Theme.ItemHeight+10)})
    local name = Create("TextLabel", {Parent=f, BackgroundTransparency=1, Font=Theme.Font, Text=opts.Text or L"Slider", TextColor3=Theme.Text, TextSize=14, TextXAlignment=Enum.TextXAlignment.Left, Size=UDim2.new(1,-60,0,22)})
    local valLabel = Create("TextButton", {Parent=f, BackgroundTransparency=1, Font=Theme.FontBold, Text="0", TextColor3=Theme.Accent, TextSize=13, TextXAlignment=Enum.TextXAlignment.Right, Size=UDim2.new(0,50,0,22), Position=UDim2.new(1,-50,0,0)})
    local track = Create("Frame", {Parent=f, BackgroundColor3=Theme.Surface, Position=UDim2.fromOffset(0,28), Size=UDim2.new(1,0,0,8), Corner=UDim.new(1,0)})
    local fill = Create("Frame", {Parent=track, BackgroundColor3=Theme.Accent, Size=UDim2.new(0,0,1,0), Corner=UDim.new(1,0)})
    local knob = Create("TextButton", {Parent=track, BackgroundColor3=Color3.new(1,1,1), AutoButtonColor=false, Text="", Size=UDim2.fromOffset(14,14), Position=UDim2.new(0,-7,0.5,-7), Corner=UDim.new(1,0)})
    if opts.Tooltip then Tooltip.attach(track, opts.Tooltip) end
    local minVal, maxVal, inc = opts.Min or 0, opts.Max or 100, opts.Increment or 1
    local cur = math.clamp(opts.Default or minVal, minVal, maxVal)
    local dragging = false
    local function setFromInput(x)
        local rel = math.clamp((x - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        cur = math.floor(minVal + (maxVal-minVal)*rel + 0.5)
        if inc > 0 then cur = math.floor(cur/inc + 0.5)*inc end
        cur = math.clamp(cur, minVal, maxVal)
        updateVisuals(true)
        if opts.Callback then opts.Callback(cur) end
    end
    local function updateVisuals(animate)
        valLabel.Text = tostring(cur)
        local ratio = (cur-minVal)/(maxVal-minVal)
        if animate then Spring(fill,{Size=UDim2.new(ratio,0,1,0)},0.12); Spring(knob,{Position=UDim2.new(ratio,-7,0.5,-7)},0.12)
        else fill.Size = UDim2.new(ratio,0,1,0); knob.Position = UDim2.new(ratio,-7,0.5,-7) end
    end
    updateVisuals(false)
    knob.InputBegan:Connect(function(inp) if inp.UserInputType==Enum.UserInputType.MouseButton1 then dragging=true; setFromInput(inp.Position.X) end end)
    track.InputBegan:Connect(function(inp) if inp.UserInputType==Enum.UserInputType.MouseButton1 then dragging=true; setFromInput(inp.Position.X) end end)
