    local name = Create("TextLabel", {Parent=f, BackgroundTransparency=1, Font=Theme.Font, Text=opts.Text or L"Color", TextColor3=Theme.Text, TextSize=14, TextXAlignment=Enum.TextXAlignment.Left, Size=UDim2.new(0.55,0,1,0)})
