local Section = {}
Section.__index = Section

function Section.new(tab, options)
	options = options or {}

	local self = setmetatable({}, Section)
	self.Tab = tab
	self.Collapsed = false
	self.Collapsible = options.Collapsible == true

	self.Frame = Create.new("Frame", {
		Name = options.Name or "Section",
		Parent = tab.Content,
		BackgroundColor3 = Theme.Surface,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		CornerRadius = Theme.CornerRadius,
	})

	self.Header = Create.new("TextButton", {
		Name = "Header",
		Parent = self.Frame,
		BackgroundTransparency = 1,
		AutoButtonColor = false,
		Font = Theme.FontBold,
		Text = options.Name or "Section",
		TextColor3 = Theme.Text,
		TextSize = 13,
		TextXAlignment = Enum.TextXAlignment.Left,
		Size = UDim2.new(1, 0, 0, Theme.SectionHeaderHeight),
	})

	Create.new("UIPadding", {
		Parent = self.Header,
		PaddingLeft = UDim.new(0, Theme.Padding),
		PaddingRight = UDim.new(0, Theme.Padding),
	})

	self.Body = Create.new("Frame", {
		Name = "Body",
		Parent = self.Frame,
		BackgroundTransparency = 1,
		Position = UDim2.fromOffset(0, Theme.SectionHeaderHeight),
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		ListLayout = { Padding = 6 },
		Padding = {
			PaddingLeft = Theme.Padding,
			PaddingRight = Theme.Padding,
			PaddingBottom = Theme.Padding,
		},
	})

	if self.Collapsible then
		self.Header.Text = "▼ " .. self.Header.Text
		self.Header.MouseButton1Click:Connect(function()
			self:ToggleCollapse()
		end)
	end

	return self
end

function Section:ToggleCollapse()
	self.Collapsed = not self.Collapsed
	self.Body.Visible = not self.Collapsed

	local prefix = self.Collapsed and "▶ " or "▼ "
	local title = self.Header.Text:gsub("^[▶▼] ", "")
	self.Header.Text = prefix .. title
end

function Section:AddButton(options)
	return Button.new(self.Body, options)
end

function Section:AddToggle(options)
	return Toggle.new(self.Body, options)
end

function Section:AddSlider(options)
	return Slider.new(self.Body, options)
end

function Section:AddDropdown(options)
	return Dropdown.new(self.Body, options)
end

function Section:AddTextbox(options)
	return Textbox.new(self.Body, options)
end

function Section:AddLabel(options)
	return Label.new(self.Body, options)
end

