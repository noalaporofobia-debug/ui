-- Slider ----------------------------------------------------------------------

local Slider = {}
Slider.__index = Slider

local function clamp(value, minValue, maxValue)
	return math.max(minValue, math.min(maxValue, value))
end

local function roundToIncrement(value, increment)
	if increment <= 0 then
		return value
	end
	return math.floor((value / increment) + 0.5) * increment
end

function Slider.new(parent, options)
	options = options or {}

	local self = setmetatable({}, Slider)
	self.Min = options.Min or 0
	self.Max = options.Max or 100
	self.Increment = options.Increment or 1
	self.Value = clamp(roundToIncrement(options.Default or self.Min, self.Increment), self.Min, self.Max)
	self.Callback = options.Callback
	self.Dragging = false

	self.Frame = Create.new("Frame", {
		Name = "SliderRow",
		Parent = parent,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, Theme.ItemHeight + 8),
	})

	self.NameLabel = Create.new("TextLabel", {
		Name = "Name",
		Parent = self.Frame,
		BackgroundTransparency = 1,
		Font = Theme.Font,
		Text = options.Name or "Slider",
		TextColor3 = Theme.Text,
		TextSize = 13,
		TextXAlignment = Enum.TextXAlignment.Left,
		Size = UDim2.new(1, -48, 0, 18),
	})

	self.ValueLabel = Create.new("TextLabel", {
		Name = "Value",
		Parent = self.Frame,
		BackgroundTransparency = 1,
		Font = Theme.FontBold,
		Text = tostring(self.Value),
		TextColor3 = Theme.Accent,
		TextSize = 13,
		TextXAlignment = Enum.TextXAlignment.Right,
		Size = UDim2.new(0, 48, 0, 18),
		Position = UDim2.new(1, -48, 0, 0),
	})

	self.Track = Create.new("Frame", {
		Name = "Track",
		Parent = self.Frame,
		BackgroundColor3 = Theme.Background,
		BorderSizePixel = 0,
		Position = UDim2.fromOffset(0, 24),
		Size = UDim2.new(1, 0, 0, 8),
		CornerRadius = UDim.new(1, 0),
	})

	self.Fill = Create.new("Frame", {
		Name = "Fill",
		Parent = self.Track,
		BackgroundColor3 = Theme.Accent,
		BorderSizePixel = 0,
		Size = UDim2.new(0, 0, 1, 0),
		CornerRadius = UDim.new(1, 0),
	})

	self.Knob = Create.new("TextButton", {
		Name = "Knob",
		Parent = self.Track,
		BackgroundColor3 = Theme.Text,
		AutoButtonColor = false,
		Text = "",
		Size = UDim2.fromOffset(14, 14),
		Position = UDim2.new(0, -7, 0.5, -7),
		CornerRadius = UDim.new(1, 0),
	})

	self:_updateVisuals(false)

	self.Knob.InputBegan:Connect(function(input)
		if
			input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch
		then
			self.Dragging = true
		end
	end)

	self.Track.InputBegan:Connect(function(input)
		if
			input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch
		then
			self:_setFromInput(input)
			self.Dragging = true
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if
			input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch
		then
			self.Dragging = false
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if
			self.Dragging
			and (
				input.UserInputType == Enum.UserInputType.MouseMovement
				or input.UserInputType == Enum.UserInputType.Touch
			)
		then
			self:_setFromInput(input)
		end
	end)

	return self
end

function Slider:_ratio()
	if self.Max == self.Min then
		return 0
	end
	return (self.Value - self.Min) / (self.Max - self.Min)
end

function Slider:_updateVisuals(animate)
	local ratio = self:_ratio()
	self.ValueLabel.Text = tostring(self.Value)

	local props = { Size = UDim2.new(ratio, 0, 1, 0) }
	local knobProps = { Position = UDim2.new(ratio, -7, 0.5, -7) }

	if animate then
		TweenUtil.play(self.Fill, props)
		TweenUtil.play(self.Knob, knobProps)
	else
		self.Fill.Size = props.Size
		self.Knob.Position = knobProps.Position
	end
end

function Slider:_setFromInput(input)
	local track = self.Track
	local relative = (input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X
	relative = clamp(relative, 0, 1)
	local rawValue = self.Min + (self.Max - self.Min) * relative
	self:SetValue(rawValue)
end

function Slider:SetValue(value)
	local newValue = clamp(roundToIncrement(value, self.Increment), self.Min, self.Max)
	if newValue == self.Value then
		self:_updateVisuals(true)
		return
	end

	self.Value = newValue
	self:_updateVisuals(true)

	if self.Callback then
		self.Callback(self.Value)
	end
end

function Slider:GetValue()
	return self.Value
end

function Slider:Destroy()
	self.Frame:Destroy()
end

-- Dropdown --------------------------------------------------------------------

local Dropdown = {}
Dropdown.__index = Dropdown

function Dropdown.new(parent, options)
	options = options or {}

	local self = setmetatable({}, Dropdown)
	self.Options = options.Options or {}
	self.Callback = options.Callback
	self.Open = false
	self.Value = options.Default or self.Options[1]

	self.Frame = Create.new("Frame", {
		Name = "DropdownRow",
		Parent = parent,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, Theme.ItemHeight),
		ClipsDescendants = false,
	})

	self.NameLabel = Create.new("TextLabel", {
		Name = "Name",
		Parent = self.Frame,
		BackgroundTransparency = 1,
		Font = Theme.Font,
		Text = options.Name or "Dropdown",
		TextColor3 = Theme.Text,
		TextSize = 13,
		TextXAlignment = Enum.TextXAlignment.Left,
		Size = UDim2.new(0.45, 0, 1, 0),
	})

	self.Selector = Create.new("TextButton", {
		Name = "Selector",
		Parent = self.Frame,
		BackgroundColor3 = Theme.Background,
		AutoButtonColor = false,
		Font = Theme.Font,
		Text = self.Value or "Select",
		TextColor3 = Theme.Text,
		TextSize = 13,
		TextTruncate = Enum.TextTruncate.AtEnd,
		Size = UDim2.new(0.55, -4, 1, 0),
		Position = UDim2.new(0.45, 4, 0, 0),
		CornerRadius = UDim.new(0, 4),
	})

	self.List = Create.new("ScrollingFrame", {
		Name = "List",
		Parent = self.Frame,
		BackgroundColor3 = Theme.Surface,
		BorderSizePixel = 0,
		Position = UDim2.new(0.45, 4, 1, 4),
		Size = UDim2.new(0.55, -4, 0, 0),
		Visible = false,
		CanvasSize = UDim2.new(0, 0, 0, 0),
		ScrollBarThickness = 3,
		ScrollBarImageColor3 = Theme.Accent,
		ZIndex = 10,
		CornerRadius = UDim.new(0, 4),
		Stroke = { Color = Theme.Border, Thickness = 1 },
	})

	self.ListContent = Create.new("Frame", {
		Name = "Content",
		Parent = self.List,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		ListLayout = { Padding = 2 },
		Padding = {
			PaddingTop = 4,
			PaddingBottom = 4,
			PaddingLeft = 4,
			PaddingRight = 4,
		},
	})

	local layout = self.ListContent:FindFirstChildOfClass("UIListLayout")
	layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		local height = math.min(layout.AbsoluteContentSize.Y + 8, 160)
		self.List.Size = UDim2.new(0.55, -4, 0, height)
		self.List.CanvasSize = UDim2.fromOffset(0, layout.AbsoluteContentSize.Y + 8)
	end)

	for _, option in ipairs(self.Options) do
		local optionButton = Create.new("TextButton", {
			Name = tostring(option),
			Parent = self.ListContent,
			BackgroundColor3 = Theme.Background,
			AutoButtonColor = false,
			Font = Theme.Font,
			Text = tostring(option),
			TextColor3 = Theme.Text,
			TextSize = 13,
			Size = UDim2.new(1, 0, 0, 28),
			CornerRadius = UDim.new(0, 4),
		})

		TweenUtil.bindHover(optionButton, Theme.Background, Theme.SurfaceHover)

		optionButton.MouseButton1Click:Connect(function()
			self:SetValue(option)
			self:Close()
		end)
	end

	self.Selector.MouseButton1Click:Connect(function()
		if self.Open then
			self:Close()
		else
			self:OpenList()
		end
	end)

	TweenUtil.bindHover(self.Selector, Theme.Background, Theme.SurfaceHover)

	return self
end

function Dropdown:OpenList()
	self.Open = true
	self.List.Visible = true
end

function Dropdown:Close()
	self.Open = false
	self.List.Visible = false
end

function Dropdown:SetValue(value)
	self.Value = value
	self.Selector.Text = tostring(value)

	if self.Callback then
		self.Callback(value)
	end
end

function Dropdown:GetValue()
	return self.Value
end

function Dropdown:Destroy()
	self.Frame:Destroy()
end

