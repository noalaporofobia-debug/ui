    local hue = Slider:Create(picker, {Text=L"Hue", Min=0,Max=360,Default=0, internal=true})
    local sat = Slider:Create(picker, {Text=L"Sat", Min=0,Max=100,Default=100, internal=true})
    local val = Slider:Create(picker, {Text=L"Val", Min=0,Max=100,Default=100, internal=true})
    picker.Size = UDim2.new(0.45,0,0,100)
    local currentColor = opts.Default or Color3.new(1,1,1)
    local updating = false
    local function updateFromHSV()
        if updating then return end
        local h = hue.GetValue()/360; local s = sat.GetValue()/100; local v = val.GetValue()/100
        currentColor = Color3.fromHSV(h,s,v); prev.BackgroundColor3 = currentColor
        if opts.Callback then opts.Callback(currentColor) end; scheduleAutosave()
    end
    local function updateSliders()
        updating = true; local h,s,v = currentColor:ToHSV()
        hue.SetValue(h*360); sat.SetValue(s*100); val.SetValue(v*100); updating = false
    end
    -- Override setter to call updateFromHSV, avoiding loop with updating flag
    local oldHueSet = hue.SetValue
    hue.SetValue = function(v)
        if not updating then oldHueSet(v); updateFromHSV() else oldHueSet(v) end
    end
    local oldSatSet = sat.SetValue
    sat.SetValue = function(v)
        if not updating then oldSatSet(v); updateFromHSV() else oldSatSet(v) end
    end
    local oldValSet = val.SetValue
    val.SetValue = function(v)
        if not updating then oldValSet(v); updateFromHSV() else oldValSet(v) end
    end
    updateSliders()
    updateFromHSV() -- ensure initial display
    if opts.Tooltip then Tooltip.attach(prev, opts.Tooltip) end
    local open = false
    local function closePicker()
        open = false; picker.Visible = false; connMgr:disconnectAll()
    end
    prev.MouseButton1Click:Connect(function()
        if open then closePicker() else
            open = true; picker.Visible = true
            picker.Size = UDim2.new(0.45,0,0,0); Spring(picker,{Size=UDim2.new(0.45,0,0,100)},0.15)
            local outsideConn = UIS.InputBegan:Connect(function(inp)
                if open and inp.UserInputType==Enum.UserInputType.MouseButton1 then
                    local pos = inp.Position
                    if not (pos.X >= picker.AbsolutePosition.X and pos.X <= picker.AbsolutePosition.X+picker.AbsoluteSize.X
                        and pos.Y >= picker.AbsolutePosition.Y and pos.Y <= picker.AbsolutePosition.Y+picker.AbsoluteSize.Y)
                        and not (pos.X >= prev.AbsolutePosition.X and pos.X <= prev.AbsolutePosition.X+prev.AbsoluteSize.X
                        and pos.Y >= prev.AbsolutePosition.Y and pos.Y <= prev.AbsolutePosition.Y+prev.AbsoluteSize.Y) then
                        closePicker()
                    end
                end
            end)
            connMgr:add(outsideConn)
        end
    end)
    prev.MouseButton2Click:Connect(function()
        ContextMenu.show(prev, {{Text=L"Copy", Callback=function() copyToClipboard(tostring(currentColor)) end}})
    end)
    local c = { Frame = f, GetValue = function() return currentColor end, SetValue = function(col) currentColor=col; prev.BackgroundColor3=col; updateSliders(); updateFromHSV(); if opts.Callback then opts.Callback(col) end; scheduleAutosave() end, Destroy = function() closePicker(); f:Destroy() end, Options = opts }
    local base = ComponentBase.new(c, "ColorPicker", opts.WindowTitle, opts.TabName, opts.SectionName, opts.Name or opts.Text)
    withAutosave(c.SetValue, c)
    return base
end

