-- Tab
local Tab = {}
function Tab:Create(window, opts)
    local tabObj = { Window = window, Name = opts.Text, Sections = {} }
    local btn = Create("TextButton", {Parent=window.TabBar, BackgroundColor3=Theme.Surface, AutoButtonColor=false, Font=Theme.Font, Text=(opts.Icon or "").." "..(opts.Text or "Tab"), TextColor3=Theme.Muted, TextSize=13, Size=UDim2.fromOffset(100, Theme.ItemHeight-8), Corner=Theme.Radius})
    local page = Create("ScrollingFrame", {Parent=window.Content, BackgroundTransparency=1, BorderSizePixel=0, Size=UDim2.fromScale(1,1), CanvasSize=UDim2.new(0,0,0,0), ScrollBarThickness=4, ScrollBarImageColor3=Theme.Accent, Visible=false})
    local content = Create("Frame", {Parent=page, BackgroundTransparency=1, Size=UDim2.new(1,0,0,0), AutomaticSize=Enum.AutomaticSize.Y, List={Padding=Theme.Padding}, Padding={PaddingLeft=Theme.Padding, PaddingRight=Theme.Padding, PaddingTop=Theme.Padding, PaddingBottom=Theme.Padding}})
    local lay = content:FindFirstChildOfClass("UIListLayout")
    lay:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function() page.CanvasSize=UDim2.fromOffset(0,lay.AbsoluteContentSize.Y+2*Theme.Padding) end)
    btn.MouseButton1Click:Connect(function() window:SetActive(tabObj) end)
    tabObj.Button = btn; tabObj.Page = page; tabObj.Content = content
    tabObj.AddSection = function(_, opt)
        local sec = Section:Create(tabObj, opt); table.insert(tabObj.Sections, sec); return sec
    end
    -- Draggable reorder
    local draggingTab = false
    btn.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingTab = true; local startPos = inp.Position; local origIndex = indexOf(window.Tabs, tabObj)
            local moveConn; moveConn = UIS.InputChanged:Connect(function(inp2)
                if draggingTab and inp2.UserInputType == Enum.UserInputType.MouseMovement then
                    local delta = inp2.Position - startPos
                    if math.abs(delta.X) > 40 then
                        local newIndex = origIndex + (delta.X>0 and 1 or -1)
                        if newIndex>=1 and newIndex<=#window.Tabs then
                            table.remove(window.Tabs, origIndex); table.insert(window.Tabs, newIndex, tabObj)
                            for i,t in ipairs(window.Tabs) do t.Button.LayoutOrder = i end; origIndex = newIndex
                        end; startPos = inp2.Position
                    end
                end
            end)
            UIS.InputEnded:Connect(function(inp2) if inp2.UserInputType==Enum.UserInputType.MouseButton1 then draggingTab=false; moveConn:Disconnect() end end)
        end
    end)
    return tabObj
end

-- Window with real redraw (state preservation)
local Window = {}
Window.__index = Window

function NovaUI:CreateWindow(opts)
    local self = setmetatable({}, Window)
    self.Tabs = {}; self.Active = nil; self.Title = opts.Title or "NovaUI"; self.Compact = false
    local localTheme = opts.Theme and ThemePresets[opts.Theme] or Theme  -- allow per-window theme
    applyTheme(opts.Theme, localTheme)  -- apply local overrides if present

    local gui = Create("ScreenGui", {Parent=Players.LocalPlayer.PlayerGui, ResetOnSpawn=false, ZIndexBehavior=Enum.ZIndexBehavior.Sibling})
    local config = {}; if readfile then pcall(function() config = HttpService:JSONDecode(readfile("NovaUI_Layout.json")) end) end
    local saved = config[self.Title] or {}
    local savedPos = saved.Position and UDim2.new(0, saved.Position.X, 0, saved.Position.Y) or opts.Position or UDim2.new(0.28,0,0.08,0)
    local savedSize = saved.Size and UDim2.fromOffset(saved.Size.X, saved.Size.Y) or opts.Size or UDim2.fromOffset(520,620)
    self.Pinned = saved.Pinned or false; self.Compact = saved.Compact or false
    if self.Compact then localTheme.Padding = 8; localTheme.ItemHeight = 34 end

    local main = Create("Frame", {Parent=gui, BackgroundColor3=localTheme.Background, BorderSizePixel=0, Size=savedSize, Position=savedPos, Corner=localTheme.Radius, Stroke={Color=localTheme.Border, Thickness=1, Transparency=0.3}})
    main.BackgroundTransparency = localTheme.GlassTransparency
    table.insert(Windows, self); self.MainFrame = main; self.ScreenGui = gui
    self.LocalTheme = localTheme

    local shadow = Create("Frame", {Parent=main, BackgroundColor3=Color3.new(0,0,0), BackgroundTransparency=localTheme.ShadowTrans, BorderSizePixel=0, Size=UDim2.new(1,12,1,12), Position=UDim2.new(0,-6,0,-6), ZIndex=-1, Corner=localTheme.Radius})
    shadow.Name = "Shadow"
    local titleBar = Create("Frame", {Parent=main, BackgroundColor3=localTheme.Surface, Size=UDim2.new(1,0,0,40)})
    local title = Create("TextLabel", {Parent=titleBar, BackgroundTransparency=1, Font=localTheme.FontBold, Text=opts.Title or "NovaUI", TextColor3=localTheme.Text, TextSize=14, TextXAlignment=Enum.TextXAlignment.Left, Position=UDim2.fromOffset(localTheme.Padding,0), Size=UDim2.new(1,-localTheme.Padding*2-40*3,1,0)})
    main.InputBegan:Connect(function(inp) if inp.UserInputType==Enum.UserInputType.MouseButton1 then NovaUI:SetActiveWindow(self) end end)

    local compactBtn = Create("TextButton", {Parent=titleBar, BackgroundColor3=localTheme.Surface, AutoButtonColor=false, Font=localTheme.FontBold, Text="◉", TextColor3=self.Compact and localTheme.Accent or localTheme.Muted, TextSize=12, Size=UDim2.fromOffset(40,40), Position=UDim2.new(1,-40*3,0,0)})
    compactBtn.MouseButton1Click:Connect(function()
        self.Compact = not self.Compact; compactBtn.TextColor3 = self.Compact and localTheme.Accent or localTheme.Muted
        if self.Compact then localTheme.Padding = 8; localTheme.ItemHeight = 34 else localTheme.Padding = 16; localTheme.ItemHeight = 44 end
        self:Redraw()
    end)

    local pinBtn = Create("TextButton", {Parent=titleBar, BackgroundColor3=localTheme.Surface, AutoButtonColor=false, Font=localTheme.FontBold, Text="📌", TextColor3=self.Pinned and localTheme.Accent or localTheme.Muted, TextSize=12, Size=UDim2.fromOffset(40,40), Position=UDim2.new(1,-40*2,0,0)})
    pinBtn.MouseButton1Click:Connect(function() self.Pinned = not self.Pinned; pinBtn.TextColor3 = self.Pinned and localTheme.Accent or localTheme.Muted; main.ZIndex = self.Pinned and 50 or 1 end)
    pinBtn.MouseEnter:Connect(function() TweenObj(pinBtn,{TextColor3=localTheme.Text}) end)
    pinBtn.MouseLeave:Connect(function() TweenObj(pinBtn,{TextColor3=self.Pinned and localTheme.Accent or localTheme.Muted}) end)

    local closeBtn = Create("TextButton", {Parent=titleBar, BackgroundColor3=localTheme.Surface, AutoButtonColor=false, Font=localTheme.FontBold, Text="✕", TextColor3=localTheme.Muted, TextSize=14, Size=UDim2.fromOffset(40,40), Position=UDim2.new(1,-40,0,0)})
    closeBtn.MouseEnter:Connect(function() TweenObj(closeBtn,{TextColor3=localTheme.Danger}) end)
    closeBtn.MouseLeave:Connect(function() TweenObj(closeBtn,{TextColor3=localTheme.Muted}) end)
    closeBtn.MouseButton1Click:Connect(function() self:Destroy() end)

    local tabBar = Create("Frame", {Parent=main, BackgroundColor3=localTheme.Surface, Position=UDim2.fromOffset(0,40), Size=UDim2.new(1,0,0,localTheme.ItemHeight), List={FillDirection=Enum.FillDirection.Horizontal, Padding=6}, Padding={PaddingLeft=localTheme.Padding, PaddingRight=localTheme.Padding, PaddingTop=6, PaddingBottom=6}})
    self.Content = Create("Frame", {Parent=main, BackgroundTransparency=1, Position=UDim2.fromOffset(0,40+localTheme.ItemHeight), Size=UDim2.new(1,0,1,-(40+localTheme.ItemHeight))})
    self.TabBar = tabBar

    local grip = Create("TextButton", {Parent=main, BackgroundColor3=localTheme.Accent, AutoButtonColor=false, Text="", Size=UDim2.fromOffset(16,16), Position=UDim2.new(1,-16,1,-16), AnchorPoint=Vector2.new(1,1), Corner=UDim.new(0,6), ZIndex=10})
    local resizing = false
    grip.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            resizing = true; local startSize = main.AbsoluteSize; local startMouse = inp.Position
            local moveConn = UIS.InputChanged:Connect(function(inp2)
                if resizing and inp2.UserInputType==Enum.UserInputType.MouseMovement then
                    local d = inp2.Position - startMouse
                    local w = math.max(360, startSize.X + d.X); local h = math.max(280, startSize.Y + d.Y)
                    main.Size = UDim2.fromOffset(w, h); self.Content.Size = UDim2.new(1,0,1,-(40+localTheme.ItemHeight))
                end
            end)
            local endConn = UIS.InputEnded:Connect(function(inp2) if inp2.UserInputType==Enum.UserInputType.MouseButton1 then resizing=false; moveConn:Disconnect(); endConn:Disconnect() end end)
        end
    end)

    Drag.enable(titleBar, main, function(finalPos)
        local x,y = finalPos.X.Offset, finalPos.Y.Offset; local w,h = main.AbsoluteSize.X, main.AbsoluteSize.Y
        local screen = workspace.CurrentCamera.ViewportSize; local snapped = false
        if x < localTheme.SnapDistance then x=0; snapped=true elseif x+w > screen.X - localTheme.SnapDistance then x=screen.X-w; snapped=true end
        if y < localTheme.SnapDistance then y=0; snapped=true elseif y+h > screen.Y - localTheme.SnapDistance then y=screen.Y-h; snapped=true end
        if snapped then Spring(main,{Position=UDim2.new(0,x,0,y)},0.2) end
    end, self)

    -- Window methods
    function self:AddTab(tabOpts)
        local tab = Tab:Create(self, tabOpts); table.insert(self.Tabs, tab)
        if not self.Active then self:SetActive(tab) end; return tab
    end
    function self:SetActive(tab)
        if self.Active then self.Active.Page.Visible = false end; self.Active = tab; tab.Page.Visible = true
        for _, t in ipairs(self.Tabs) do
            local active = t==tab; Spring(t.Button,{BackgroundColor3=active and localTheme.Accent or localTheme.Surface, TextColor3=active and Color3.new(1,1,1) or localTheme.Muted},0.2,0.8,0.6)
        end
    end
    function self:Redraw()
        -- Save state from old components
        local tabsData = {}
        for _, tab in ipairs(self.Tabs) do
            local sectionsData = {}
            for _, sec in ipairs(tab.Sections) do
                local comps = {}
                for _, compData in ipairs(sec.Components) do
                    local comp = compData.component
                    local newOpts = {}
                    for k,v in pairs(compData.options) do newOpts[k] = v end
                    -- Save current value into Default
                    if comp.GetValue then newOpts.Default = comp:GetValue()
                    elseif comp.GetText then newOpts.Default = comp:GetText() end
                    table.insert(comps, {type = compData.type, options = newOpts})
                end
                table.insert(sectionsData, {options = sec.Options, components = comps})
            end
            table.insert(tabsData, {tabOptions = {Text = tab.Name, Icon = ""}, sections = sectionsData})
        end
        -- Destroy old UI
        for _, tab in ipairs(self.Tabs) do
            tab.Content:Destroy(); tab.Page:Destroy(); tab.Button:Destroy()
        end
        self.Tabs = {}
        -- Rebuild with current localTheme
        for _, data in ipairs(tabsData) do
            local newTab = self:AddTab(data.tabOptions)
            for _, secData in ipairs(data.sections) do
                local newSec = newTab:AddSection(secData.options)
                for _, compData in ipairs(secData.components) do
                    local creator = nil
                    if compData.type == "Button" then creator = Button.Create
                    elseif compData.type == "Toggle" then creator = Toggle.Create
                    elseif compData.type == "Slider" then creator = Slider.Create
                    elseif compData.type == "Dropdown" then creator = Dropdown.Create
                    elseif compData.type == "Keybind" then creator = Keybind.Create
                    elseif compData.type == "ColorPicker" then creator = ColorPicker.Create
                    elseif compData.type == "Textbox" then creator = Textbox.Create
                    elseif compData.type == "RadioGroup" then creator = RadioGroup.Create
                    elseif compData.type == "Checkbox" then creator = Checkbox.Create
                    elseif compData.type == "ProgressBar" then creator = ProgressBar.Create
                    elseif compData.type == "List" then creator = List.Create
                    elseif compData.type == "Bind" then creator = Bind.Create
                    elseif compData.type == "Timer" then creator = Timer.Create
                    elseif compData.type == "Label" then creator = Label.Create
                    elseif compData.type == "Paragraph" then creator = Paragraph.Create
                    end
                    if creator then
                        local compOpts = compData.options
                        compOpts.WindowTitle = self.Title; compOpts.TabName = newTab.Name; compOpts.SectionName = secData.options.Text or ""
                        local newComp = creator(newSec.Body, compOpts)
                        table.insert(newSec.Components, {type = compData.type, component = newComp, options = compOpts})
                        NovaUI:TriggerHook("OnComponentAdded", newComp, compData.type, self, newTab, newSec, compOpts)
                    end
                end
            end
        end
        NovaUI:Notify({Title="Redraw", Text=L"CompactToggled", Duration=2})
    end
    function self:Destroy()
        -- Save layout and config
        local pos = main.Position; local size = main.AbsoluteSize
        local layout = {}
        if readfile then pcall(function() layout = HttpService:JSONDecode(readfile("NovaUI_Layout.json")) end) end
        layout[self.Title] = { Position = {X=pos.X.Offset, Y=pos.Y.Offset}, Size = {X=size.X, Y=size.Y}, Pinned = self.Pinned, Compact = self.Compact }
        if writefile then pcall(function() writefile("NovaUI_Layout.json", HttpService:JSONEncode(layout)) end) end
        saveAllConfigs()
        -- Destroy all components recursively
        for _, tab in ipairs(self.Tabs) do
            for _, sec in ipairs(tab.Sections) do
                for _, compData in ipairs(sec.Components) do
                    if compData.component and compData.component.Destroy then compData.component:Destroy() end
                end
                sec.Body:Destroy(); sec.Frame:Destroy()
            end
            tab.Content:Destroy(); tab.Page:Destroy(); tab.Button:Destroy()
        end
        for i, w in ipairs(Windows) do if w==self then table.remove(Windows,i); break end end
        gui:Destroy()
    end

    -- Search (full container hiding)
    self.SearchFrame = nil
    local function toggleSearch()
        if ActiveWindow ~= self then return end
        if self.SearchFrame then self.SearchFrame:Destroy(); self.SearchFrame=nil; return end
        self.SearchFrame = Create("Frame", {Parent=main, BackgroundColor3=localTheme.Surface, BorderSizePixel=0, Size=UDim2.new(1,-20,0,36), Position=UDim2.new(0,10,0,40+localTheme.ItemHeight+5), Corner=localTheme.Radius, ZIndex=10})
        local box = Create("TextBox", {Parent=self.SearchFrame, BackgroundColor3=localTheme.Background, ClearTextOnFocus=false, Font=localTheme.Font, PlaceholderText=L"Search", PlaceholderColor3=localTheme.Muted, Text="", TextColor3=localTheme.Text, TextSize=14, Size=UDim2.new(1,-16,1,0), Position=UDim2.fromOffset(8,0), Corner=localTheme.Radius})
        box:CaptureFocus()
        local containerMap = {}
        local function mapTexts(frame)
            for _, child in ipairs(frame:GetChildren()) do
                if child:IsA("TextLabel") or child:IsA("TextButton") then
                    local text = child.Text:lower()
                    local container = child.Parent
                    while container and container.Parent ~= frame and container ~= self.Content do container = container.Parent end
                    if container and container:IsA("Frame") then
                        if not containerMap[container] then containerMap[container] = {} end
                        table.insert(containerMap[container], text)
                    end
                elseif child:IsA("Frame") or child:IsA("ScrollingFrame") then
                    mapTexts(child)
                end
            end
        end
        for _, tab in ipairs(self.Tabs) do
            for _, sec in ipairs(tab.Sections) do
                if sec.Body then mapTexts(sec.Body) end
            end
        end
        box:GetPropertyChangedSignal("Text"):Connect(function()
            local query = box.Text:lower()
            for container, texts in pairs(containerMap) do
                local found = false
                for _, t in ipairs(texts) do if t:find(query) then found=true; break end end
                container.Visible = (query=="" or found)
            end
        end)
        box.FocusLost:Connect(function()
            self.SearchFrame:Destroy(); self.SearchFrame=nil
            for container,_ in pairs(containerMap) do container.Visible = true end
        end)
    end

    UIS.InputBegan:Connect(function(inp, gp)
        if gp then return end
        if ActiveWindow == self then
            if inp.KeyCode == Enum.KeyCode.F and UIS:IsKeyDown(Enum.KeyCode.LeftControl) then toggleSearch()
            elseif inp.KeyCode == Enum.KeyCode.Escape then self:Destroy()
            elseif inp.KeyCode == Enum.KeyCode.Grave then NovaUI:ToggleConsole() end
        end
    end)

    -- Entrance animation
    main.BackgroundTransparency = 1; main.Size -= UDim2.fromOffset(20,20); main.Position += UDim2.fromOffset(10,10)
    Spring(main,{BackgroundTransparency=localTheme.GlassTransparency, Size=savedSize, Position=savedPos},0.3,0.7,0.5)

    NovaUI:SetActiveWindow(self)
    NovaUI:TriggerHook("OnWindowCreated", self)
    return self
end

