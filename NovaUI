-- Notifications with icon and progress
local notifGui, notifStack
local activeNotifs = {}
function NovaUI:Notify(opts)
    if not notifGui then
        notifGui = Create("ScreenGui", {Parent=Players.LocalPlayer.PlayerGui, ResetOnSpawn=false, ZIndexBehavior=Enum.ZIndexBehavior.Sibling})
        notifStack = Create("Frame", {Parent=notifGui, BackgroundTransparency=1, Position=UDim2.new(1,-Theme.Padding,0,Theme.Padding), Size=UDim2.fromOffset(330,0), AnchorPoint=Vector2.new(1,0), AutomaticSize=Enum.AutomaticSize.Y, List={Padding=8, HorizontalAlignment=Enum.HorizontalAlignment.Right}})
    end
    if Theme.SoundEnabled then PlaySound("rbxassetid://9116338654") end
    local iconChar = {Info = "ℹ️", Success = "✅", Warning = "⚠️", Error = "❌"}
    local frame = Create("Frame", {Parent=notifStack, BackgroundColor3=Theme.Surface, BorderSizePixel=0, Size=UDim2.fromOffset(310,0), AutomaticSize=Enum.AutomaticSize.Y, Corner=Theme.Radius, Stroke={Color=opts.Type=="Error" and Theme.Danger or Theme.Accent, Thickness=1.5, Transparency=0.4}})
    local icon = opts.Icon or (opts.Type and iconChar[opts.Type] or "")
    local title = Create("TextLabel", {Parent=frame, BackgroundTransparency=1, Font=Theme.FontBold, Text=(icon~="" and icon.." " or "")..(opts.Title or ""), TextColor3=opts.Type=="Error" and Theme.Danger or Theme.Accent, TextSize=13, TextXAlignment=Enum.TextXAlignment.Left, Position=UDim2.fromOffset(Theme.Padding,Theme.Padding), Size=UDim2.new(1,-Theme.Padding*2-20,0,18)})
    local body = Create("TextLabel", {Parent=frame, BackgroundTransparency=1, Font=Theme.Font, Text=opts.Text or "", TextColor3=Theme.Muted, TextSize=12, TextWrapped=true, TextXAlignment=Enum.TextXAlignment.Left, TextYAlignment=Enum.TextYAlignment.Top, Position=UDim2.fromOffset(Theme.Padding,Theme.Padding+22), Size=UDim2.new(1,-Theme.Padding*2,0,0), AutomaticSize=Enum.AutomaticSize.Y})
    local close = Create("TextButton", {Parent=frame, BackgroundTransparency=1, Font=Theme.FontBold, Text="✕", TextColor3=Theme.Muted, TextSize=14, Size=UDim2.fromOffset(18,18), Position=UDim2.new(1,-22,0,4)})
    close.MouseButton1Click:Connect(function()
        frame:Destroy(); for i,item in ipairs(activeNotifs) do if item.Frame==frame then table.remove(activeNotifs,i); break end end
    end)
    -- Progress bar if duration > 0
    local progressTrack, progressFill
    if opts.Duration and opts.Duration > 0 then
        progressTrack = Create("Frame", {Parent=frame, BackgroundColor3=Theme.Background, BorderSizePixel=0, Size=UDim2.new(1,-Theme.Padding*2,0,4), Position=UDim2.new(0,Theme.Padding,1,-(Theme.Padding+4)), Corner=UDim.new(1,0)})
        progressFill = Create("Frame", {Parent=progressTrack, BackgroundColor3=Theme.Accent, Size=UDim2.fromScale(1,1), Corner=UDim.new(1,0)})
    end
    table.insert(activeNotifs, {Frame=frame})
    if #activeNotifs > 5 then local oldest = table.remove(activeNotifs,1); oldest.Frame:Destroy() end
    for _, item in ipairs(activeNotifs) do Spring(item.Frame,{Position=item.Frame.Position+UDim2.new(0,0,0,8)},0.15,0.9,0.7) end
    frame.BackgroundTransparency=1; title.TextTransparency=1; body.TextTransparency=1
    frame.Position = UDim2.new(1,30,0,frame.Position.Y.Offset)
    Spring(frame,{Position=UDim2.new(1,0,0,frame.Position.Y.Offset), BackgroundTransparency=0},0.25,0.8,0.6)
    TweenObj(title,{TextTransparency=0}); TweenObj(body,{TextTransparency=0})
    local dur = opts.Duration or 4
    if dur > 0 and progressFill then
        TweenObj(progressFill, {Size=UDim2.fromScale(0,1)}, dur, Enum.EasingStyle.Linear)
    end
    if dur > 0 then
        task.delay(dur, function()
            if not frame.Parent then return end
            TweenObj(frame,{BackgroundTransparency=1}); TweenObj(title,{TextTransparency=1}); TweenObj(body,{TextTransparency=1})
            task.delay(0.15, function()
                if frame.Parent then frame:Destroy() end
                for i,item in ipairs(activeNotifs) do if item.Frame==frame then table.remove(activeNotifs,i); break end end
            end)
        end)
    end
    return { Destroy = function() if frame.Parent then frame:Destroy() end end }
end

-- Layout Save/Load
function NovaUI:SaveLayout()
    local data = {}
    for _, w in ipairs(Windows) do
        local pos = w.MainFrame.Position; local size = w.MainFrame.AbsoluteSize
        data[w.Title] = { Position = {X=pos.X.Offset, Y=pos.Y.Offset}, Size = {X=size.X, Y=size.Y}, Pinned = w.Pinned, Compact = w.Compact }
    end
    if writefile then pcall(function() writefile("NovaUI_Layout.json", HttpService:JSONEncode(data)) end); NovaUI:Notify({Title=L"LayoutSaved", Duration=2}) end
end

function NovaUI:LoadLayout()
    if not readfile then return NovaUI:Notify({Title="Error", Text="Cannot read files", Duration=2}) end
    local content = readfile("NovaUI_Layout.json"); local data = HttpService:JSONDecode(content)
    for _, w in ipairs(Windows) do
        local saved = data[w.Title]
        if saved then
            w.MainFrame.Position = UDim2.new(0, saved.Position.X, 0, saved.Position.Y); w.MainFrame.Size = UDim2.fromOffset(saved.Size.X, saved.Size.Y)
            w.Pinned = saved.Pinned; w.Compact = saved.Compact
            if w.Compact then w:Redraw() end
        end
    end
    NovaUI:Notify({Title=L"LayoutLoaded", Duration=2})
end

-- Plugin System
NovaUI.Plugins = {}
NovaUI.Hooks = {}
function NovaUI:RegisterPlugin(name, callback)
    NovaUI.Plugins[name] = callback
    if NovaUI.Hooks[name] then for _, hook in ipairs(NovaUI.Hooks[name]) do hook(callback) end end
end
function NovaUI:AddHook(hookName, fn)
    if not NovaUI.Hooks[hookName] then NovaUI.Hooks[hookName] = {} end; table.insert(NovaUI.Hooks[hookName], fn)
end
function NovaUI:TriggerHook(hookName, ...)
    if NovaUI.Hooks[hookName] then for _, fn in ipairs(NovaUI.Hooks[hookName]) do fn(...) end end
end

