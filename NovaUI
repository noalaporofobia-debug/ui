function Textbox.new(parent, options)
	options = options or {}

	local self = setmetatable({}, Textbox)
	self.Callback = options.Callback
	self.CallbackOn = options.CallbackOn or "FocusLost"

	self.Frame = Create.new("Frame", {
		Name = "TextboxRow",
		Parent = parent,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, Theme.ItemHeight),
	})

	self.NameLabel = Create.new("TextLabel", {
		Name = "Name",
		Parent = self.Frame,
		BackgroundTransparency = 1,
		Font = Theme.Font,
		Text = options.Name or "Textbox",
		TextColor3 = Theme.Text,
		TextSize = 13,
		TextXAlignment = Enum.TextXAlignment.Left,
		Size = UDim2.new(0.45, 0, 1, 0),
	})

	self.Input = Create.new("TextBox", {
		Name = "Input",
		Parent = self.Frame,
		BackgroundColor3 = Theme.Background,
		ClearTextOnFocus = false,
		Font = Theme.Font,
		PlaceholderText = options.Placeholder or "",
		PlaceholderColor3 = Theme.Muted,
		Text = options.Default or "",
		TextColor3 = Theme.Text,
		TextSize = 13,
		TextXAlignment = Enum.TextXAlignment.Left,
		Size = UDim2.new(0.55, -4, 1, 0),
		Position = UDim2.new(0.45, 4, 0, 0),
		CornerRadius = UDim.new(0, 4),
		Padding = { PaddingLeft = 8, PaddingRight = 8 },
	})

	self.Input.FocusLost:Connect(function(enterPressed)
		if self.CallbackOn == "FocusLost" and self.Callback then
			self.Callback(self.Input.Text, enterPressed)
		end
	end)

	self.Input:GetPropertyChangedSignal("Text"):Connect(function()
		if self.CallbackOn == "Changed" and self.Callback then
			self.Callback(self.Input.Text, false)
		end
	end)

	self.Input.Focused:Connect(function()
		TweenUtil.play(self.Input, { BackgroundColor3 = Theme.Surface })
	end)

	self.Input.FocusLost:Connect(function()
		TweenUtil.play(self.Input, { BackgroundColor3 = Theme.Background })
	end)

	return self
end

function Textbox:SetText(text)
	self.Input.Text = text
end

function Textbox:GetText()
	return self.Input.Text
end

function Textbox:Destroy()
	self.Frame:Destroy()
end

