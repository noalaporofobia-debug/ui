        Size = UDim2.new(0.45, 0, 1, 0),
    })
    self.Selector = Create.new("TextButton", {
        Name = "Selector",
        Parent = self.Frame,
        BackgroundColor3 = Theme.Surface,
        AutoButtonColor = false,
        Font = Theme.Font,
        Text = self.Value or "Select",
        TextColor3 = Theme.Text,
        TextSize = 13,
        TextTruncate = Enum.TextTruncate.AtEnd,
        Size = UDim2.new(0.55, -4, 1, 0),
        Position = UDim2.new(0.45, 4, 0, 0),
        CornerRadius = UDim.new(0, 6),
    })
    self.List = Create.new("ScrollingFrame", {
        Name = "List",
        Parent = self.Frame,
        BackgroundColor3 = Theme.Surface,
        BorderSizePixel = 0,
        Position = UDim2.new(0.45, 4, 1, 4),
        Size = UDim2.new(0.55, -4, 0, 0),
        Visible = false,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        ScrollBarThickness = Theme.ScrollbarThickness,
        ScrollBarImageColor3 = Theme.Accent,
        ZIndex = 10,
        CornerRadius = UDim.new(0, 6),
        Stroke = { Color = Theme.Border, Thickness = 1 },
    })
    self.ListContent = Create.new("Frame", {
        Name = "Content",
        Parent = self.List,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        ListLayout = { Padding = 2 },
        Padding = { PaddingTop = 4, PaddingBottom = 4, PaddingLeft = 4, PaddingRight = 4 },
    })
    local layout = self.ListContent:FindFirstChildOfClass("UIListLayout")
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        local contentHeight = layout.AbsoluteContentSize.Y + 8
        local maxHeight = 160
        local h = math.min(contentHeight, maxHeight)
        self.List.Size = UDim2.new(0.55, -4, 0, h)
        self.List.CanvasSize = UDim2.fromOffset(0, contentHeight)
    end)
    for _, opt in ipairs(self.Options) do
        local btn = Create.new("TextButton", {
            Parent = self.ListContent,
            BackgroundColor3 = Theme.Background,
            AutoButtonColor = false,
            Font = Theme.Font,
            Text = tostring(opt),
            TextColor3 = Theme.Text,
            TextSize = 13,
            Size = UDim2.new(1, 0, 0, 30),
            CornerRadius = UDim.new(0, 4),
        })
        TweenUtil.bindHover(btn, Theme.Background, Theme.SurfaceHover)
        btn.MouseButton1Click:Connect(function()
            self:SetValue(opt)
            self:Close()
        end)
    end
    self.Selector.MouseButton1Click:Connect(function()
        if self.Open then self:Close() else self:OpenList() end
    end)
    TweenUtil.bindHover(self.Selector, Theme.Surface, Theme.SurfaceHover)
    -- Cerrar al hacer clic fuera
    local function closeOutside(input)
        if self.Open and input.UserInputType == Enum.UserInputType.MouseButton1 then
            local pos = input.Position
            local listPos = self.List.AbsolutePosition
            local listSize = self.List.AbsoluteSize
            local selPos = self.Selector.AbsolutePosition
            local selSize = self.Selector.AbsoluteSize
            if not (pos.X >= listPos.X and pos.X <= listPos.X + listSize.X and pos.Y >= listPos.Y and pos.Y <= listPos.Y + listSize.Y)
                and not (pos.X >= selPos.X and pos.X <= selPos.X + selSize.X and pos.Y >= selPos.Y and pos.Y <= selPos.Y + selSize.Y) then
                self:Close()
            end
        end
    end
    UserInputService.InputBegan:Connect(closeOutside)
    return self
end
function Dropdown:OpenList()
    self.Open = true
    self.List.Visible = true
end
function Dropdown:Close()
    self.Open = false
    self.List.Visible = false
end
function Dropdown:SetValue(value)
    self.Value = value
    self.Selector.Text = tostring(value)
    if self.Callback then self.Callback(value) end
end
function Dropdown:GetValue() return self.Value end
function Dropdown:Destroy() self.Frame:Destroy() end

