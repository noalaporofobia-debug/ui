-- Drag with docking
local Drag = {}
function Drag.enable(handle, target, onRelease, windowObj)
    local down, startPos, startMouse
    handle.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            down = true; startPos = target.Position; startMouse = inp.Position
            if windowObj then NovaUI:SetActiveWindow(windowObj) end
        end
    end)
    UIS.InputChanged:Connect(function(inp)
        if down and inp.UserInputType == Enum.UserInputType.MouseMovement then
            local d = inp.Position - startMouse
            local x = math.clamp(startPos.X.Offset + d.X, 0, workspace.CurrentCamera.ViewportSize.X - target.AbsoluteSize.X)
            local y = math.clamp(startPos.Y.Offset + d.Y, 0, workspace.CurrentCamera.ViewportSize.Y - target.AbsoluteSize.Y)
            for _, other in ipairs(Windows) do
                if other.MainFrame ~= target then
                    local ox,oy = other.MainFrame.Position.X.Offset, other.MainFrame.Position.Y.Offset
                    local ow,oh = other.MainFrame.AbsoluteSize.X, other.MainFrame.AbsoluteSize.Y
                    local tw,th = target.AbsoluteSize.X, target.AbsoluteSize.Y
                    if math.abs(x+tw-ox) < 30 then x = ox-tw end
                    if math.abs(x-(ox+ow)) < 30 then x = ox+ow end
                    if math.abs(y+th-oy) < 30 then y = oy-th end
                    if math.abs(y-(oy+oh)) < 30 then y = oy+oh end
                end
            end
            target.Position = UDim2.new(0, x, 0, y)
        end
    end)
    UIS.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            down = false
            if onRelease then onRelease(target.Position) end
        end
    end)
end

function NovaUI:SetActiveWindow(win)
    if ActiveWindow == win then return end
    ActiveWindow = win
    for _, w in ipairs(Windows) do
        if w.MainFrame then
            w.MainFrame.ZIndex = (w == win) and 10 or 1
            if w.MainFrame:FindFirstChild("Shadow") then
                w.MainFrame.Shadow.BackgroundTransparency = (w == win) and Theme.ShadowTrans - 0.1 or Theme.ShadowTrans
            end
        end
    end
end

-- Tooltip (with safety)
local Tooltip = {}
function Tooltip.attach(gui, text)
    local tip, cancelToken
    local function clear() if tip and tip.Parent then tip:Destroy(); tip = nil end end
    gui.MouseEnter:Connect(function()
        if cancelToken then cancelToken:cancel() end
        clear()
        tip = Create("Frame", {
            Parent = gui, BackgroundColor3 = Theme.Background, BorderSizePixel = 0,
            Size = UDim2.new(0,0,0,0), AutomaticSize = Enum.AutomaticSize.XY,
            Position = UDim2.new(1,8,0,0), Corner = Theme.Radius,
            Stroke = {Color=Theme.Border, Thickness=1, Transparency=0.5}, ZIndex = 100,
        })
        local lbl = Create("TextLabel", {
            Parent=tip, BackgroundTransparency=1, Font=Theme.Font, Text=text,
            TextColor3=Theme.Text, TextSize=12, Size=UDim2.new(0,0,0,0),
            AutomaticSize=Enum.AutomaticSize.XY,
            Padding={PaddingLeft=8, PaddingRight=8, PaddingTop=6, PaddingBottom=6},
        })
        tip.BackgroundTransparency = 1
        Spring(tip, {BackgroundTransparency=0.1}, 0.15)
    end)
    gui.MouseLeave:Connect(function()
        cancelToken = task.delay(0.2, clear)
    end)
end

-- Context Menu
local ContextMenu = {}
function ContextMenu.show(gui, items)
    local menu = Create("Frame", {
        Parent = gui, BackgroundColor3 = Theme.Surface, BorderSizePixel = 0,
        Size = UDim2.new(0,0,0,0), AutomaticSize = Enum.AutomaticSize.Y,
        Position = UDim2.new(0,0,0,0), Corner = Theme.Radius,
        Stroke = {Color=Theme.Border, Thickness=1, Transparency=0.5}, ZIndex = 100,
    })
    Create("UIListLayout", {Parent=menu, SortOrder=Enum.SortOrder.LayoutOrder, Padding=UDim.new(0,2)})
    for _, item in ipairs(items) do
        local btn = Create("TextButton", {
            Parent=menu, BackgroundColor3=Theme.Surface, AutoButtonColor=false,
            Font=Theme.Font, Text=item.Text, TextColor3=Theme.Text, TextSize=13,
            Size=UDim2.new(0,130,0,30), Corner=UDim.new(0,4),
        })
        btn.MouseEnter:Connect(function() TweenObj(btn,{BackgroundColor3=Theme.SurfaceAlt}) end)
        btn.MouseLeave:Connect(function() TweenObj(btn,{BackgroundColor3=Theme.Surface}) end)
        btn.MouseButton1Click:Connect(function()
            menu:Destroy()
            if item.Callback then item.Callback() end
        end)
    end
    local pos = UIS:GetMouseLocation()
    menu.Position = UDim2.new(0, pos.X - gui.AbsolutePosition.X, 0, pos.Y - gui.AbsolutePosition.Y)
    local conn
    conn = UIS.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            if not (inp.Position.X >= menu.AbsolutePosition.X and inp.Position.X <= menu.AbsolutePosition.X + menu.AbsoluteSize.X
                and inp.Position.Y >= menu.AbsolutePosition.Y and inp.Position.Y <= menu.AbsolutePosition.Y + menu.AbsoluteSize.Y) then
                menu:Destroy(); conn:Disconnect()
            end
        end
    end)
end

-- Clipboard
local function copyToClipboard(text)
    local ok = pcall(function() setclipboard(text) end)
    if not ok then NovaUI:Notify({Title="Error", Text=L"ClipboardNA", Duration=2, Type="Error"}) end
end
local function pasteFromClipboard()
    return pcall(function() return getclipboard() end) and getclipboard() or ""
end

-- Autosave
local function scheduleAutosave()
    if autosaveDebounce then return end
    autosaveDebounce = true
    task.delay(1.5, function()
        saveAllConfigs()
        autosaveDebounce = false
    end)
end

local function getComponentId(comp) return comp and comp.__id end
local function registerComponent(comp, type, windowTitle, tabName, sectionName, name)
    if not comp then return end
    local id = HttpService:GenerateGUID(false)
    comp.__id = id
    ComponentRegistry[id] = { component = comp, type = type, window = windowTitle, tab = tabName, section = sectionName, name = name }
end
local function unregisterComponent(comp)
    if comp and comp.__id then ComponentRegistry[comp.__id] = nil end
end

local function saveAllConfigs()
    local data = {}
    for id, entry in pairs(ComponentRegistry) do
        local comp = entry.component
        if comp and comp.GetValue then data[id] = { value = comp:GetValue() }
        elseif comp and comp.GetText then data[id] = { value = comp:GetText() } end
    end
    if writefile then pcall(function() writefile("NovaUI_Components.json", HttpService:JSONEncode(data)) end) end
end

local function loadAllConfigs()
    if not readfile then return end
    local success, content = pcall(function() return readfile("NovaUI_Components.json") end)
    if not success or not content then return end
    local data = HttpService:JSONDecode(content)
    for id, entry in pairs(data) do
        local reg = ComponentRegistry[id]
        if reg and reg.component then
            local comp = reg.component
            if comp.SetValue and entry.value then comp:SetValue(entry.value)
            elseif comp.SetText and entry.value then comp:SetText(entry.value) end
        end
    end
end

-- Component Base
local ComponentBase = {}
ComponentBase.__index = ComponentBase
function ComponentBase.new(comp, type, windowTitle, tabName, sectionName, name)
    local self = setmetatable({}, ComponentBase)
    self.component = comp
    registerComponent(comp, type, windowTitle, tabName, sectionName, name)
    return self
end
function ComponentBase:Animate(props) Spring(self.component.Frame or self.component.Button or self.component, props) end
function ComponentBase:Destroy()
    if self.component and self.component.Destroy then self.component:Destroy() end
    unregisterComponent(self.component)
end

-- Helper to wrap setter for autosave
local function withAutosave(originalSet, comp)
    if not originalSet then return end
    local old = comp.SetValue or comp.SetText
    if not old then return end
    if comp.SetValue then
        comp.SetValue = function(val) old(val); scheduleAutosave() end
    end
    if comp.SetText then
        comp.SetText = function(txt) old(txt); scheduleAutosave() end
    end
end

