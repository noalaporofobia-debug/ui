--[[
	Roblox UI Library v1 — single file bundle.
	Usage:
		local UI = loadstring(game:HttpGet("RAW_URL/lib/init.lua"))()
		local UI = require(path.to.lib)
]]

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")

-- Theme -----------------------------------------------------------------------

local Theme = {
	Background = Color3.fromRGB(25, 25, 25),
	Surface = Color3.fromRGB(35, 35, 35),
	SurfaceHover = Color3.fromRGB(45, 45, 45),
	Accent = Color3.fromRGB(0, 170, 255),
	AccentDark = Color3.fromRGB(0, 130, 200),
	Text = Color3.fromRGB(255, 255, 255),
	Muted = Color3.fromRGB(180, 180, 180),
	Border = Color3.fromRGB(255, 255, 255),
	Danger = Color3.fromRGB(220, 60, 60),
	CornerRadius = UDim.new(0, 6),
	Font = Enum.Font.Gotham,
	FontBold = Enum.Font.GothamBold,
	Padding = 8,
	ItemHeight = 36,
	TitleBarHeight = 32,
	TabBarHeight = 36,
	SectionHeaderHeight = 28,
}

function Theme.Apply(overrides)
	if not overrides then
		return
	end
	for key, value in pairs(overrides) do
		Theme[key] = value
	end
end

-- Create ----------------------------------------------------------------------

local Create = {}

function Create.new(className, props)
	local instance = Instance.new(className)

	for key, value in pairs(props or {}) do
		if key == "CornerRadius" then
			local corner = Instance.new("UICorner")
			corner.CornerRadius = value
			corner.Parent = instance
		elseif key == "Stroke" then
			local stroke = Instance.new("UIStroke")
			stroke.Color = value.Color or Theme.Border
			stroke.Thickness = value.Thickness or 1
			stroke.Transparency = value.Transparency or 0
			stroke.ApplyStrokeMode = value.ApplyStrokeMode or Enum.ApplyStrokeMode.Border
			stroke.Parent = instance
		elseif key == "Padding" then
			local padding = Instance.new("UIPadding")
			for side, amount in pairs(value) do
				padding[side] = UDim.new(0, amount)
			end
			padding.Parent = instance
		elseif key == "ListLayout" then
			local layout = Instance.new("UIListLayout")
			layout.SortOrder = Enum.SortOrder.LayoutOrder
			layout.Padding = UDim.new(0, value.Padding or Theme.Padding)
			layout.FillDirection = value.FillDirection or Enum.FillDirection.Vertical
			layout.HorizontalAlignment = value.HorizontalAlignment or Enum.HorizontalAlignment.Left
			layout.VerticalAlignment = value.VerticalAlignment or Enum.VerticalAlignment.Top
			layout.Parent = instance
		else
			instance[key] = value
		end
	end

	return instance
end

-- Drag ------------------------------------------------------------------------

local Drag = {}

function Drag.enable(handle, target)
	local dragging = false
	local dragStart
	local startPos

	handle.InputBegan:Connect(function(input)
		if
			input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch
		then
			dragging = true
			dragStart = input.Position
			startPos = target.Position

			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if
			dragging
			and (
				input.UserInputType == Enum.UserInputType.MouseMovement
				or input.UserInputType == Enum.UserInputType.Touch
			)
		then
			local delta = input.Position - dragStart
			target.Position = UDim2.new(
				startPos.X.Scale,
				startPos.X.Offset + delta.X,
				startPos.Y.Scale,
				startPos.Y.Offset + delta.Y
			)
		end
	end)
end

-- Tween -----------------------------------------------------------------------

local TweenUtil = {}

function TweenUtil.play(instance, props, duration, style, direction)
	local info = TweenInfo.new(
		duration or 0.15,
		style or Enum.EasingStyle.Quad,
		direction or Enum.EasingDirection.Out
	)
	local tween = TweenService:Create(instance, info, props)
	tween:Play()
	return tween
end

function TweenUtil.bindHover(button, normalColor, hoverColor)
	button.MouseEnter:Connect(function()
		TweenUtil.play(button, { BackgroundColor3 = hoverColor })
	end)

	button.MouseLeave:Connect(function()
		TweenUtil.play(button, { BackgroundColor3 = normalColor })
	end)
end

