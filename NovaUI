local function applyTheme(overrides)
    if not overrides then return end
    for k, v in pairs(overrides) do
        Theme[k] = v
    end
end

-- Utility Functions -----------------------------------------------------------
local Create = {}
function Create.new(className, props)
    local instance = Instance.new(className)
    for key, value in pairs(props or {}) do
        if key == "CornerRadius" then
            local corner = Instance.new("UICorner")
            corner.CornerRadius = value
            corner.Parent = instance
        elseif key == "Stroke" then
            local stroke = Instance.new("UIStroke")
            stroke.Color = value.Color or Theme.Border
            stroke.Thickness = value.Thickness or 1
            stroke.Transparency = value.Transparency or 0
            stroke.ApplyStrokeMode = value.ApplyStrokeMode or Enum.ApplyStrokeMode.Border
            stroke.Parent = instance
        elseif key == "Gradient" then
            local gradient = Instance.new("UIGradient")
            for k2, v2 in pairs(value) do
                gradient[k2] = v2
            end
            gradient.Parent = instance
        elseif key == "Padding" then
            local pad = Instance.new("UIPadding")
            for side, amount in pairs(value) do
                pad[side] = UDim.new(0, amount)
            end
            pad.Parent = instance
        elseif key == "ListLayout" then
            local layout = Instance.new("UIListLayout")
            layout.SortOrder = Enum.SortOrder.LayoutOrder
            layout.Padding = UDim.new(0, value.Padding or Theme.Padding)
            layout.FillDirection = value.FillDirection or Enum.FillDirection.Vertical
            layout.HorizontalAlignment = value.HorizontalAlignment or Enum.HorizontalAlignment.Left
            layout.VerticalAlignment = value.VerticalAlignment or Enum.VerticalAlignment.Top
            layout.Parent = instance
        else
            instance[key] = value
        end
    end
    return instance
end

local TweenUtil = {}
function TweenUtil.play(instance, props, duration, style, direction)
    local info = TweenInfo.new(
        duration or Theme.AnimationSpeed,
        style or Enum.EasingStyle.Quad,
        direction or Enum.EasingDirection.Out
    )
    local tween = TweenService:Create(instance, info, props)
    tween:Play()
    return tween
end

function TweenUtil.bindHover(button, normalColor, hoverColor)
    button.MouseEnter:Connect(function()
        TweenUtil.play(button, { BackgroundColor3 = hoverColor })
    end)
    button.MouseLeave:Connect(function()
        TweenUtil.play(button, { BackgroundColor3 = normalColor })
    end)
end

local Drag = {}
function Drag.enable(handle, target)
    local dragging, dragStart, startPos
    local screenSize = workspace.CurrentCamera.ViewportSize

    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = target.Position
            UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            local newX = math.clamp(startPos.X.Offset + delta.X, 0, screenSize.X - target.AbsoluteSize.X)
            local newY = math.clamp(startPos.Y.Offset + delta.Y, 0, screenSize.Y - target.AbsoluteSize.Y)
            target.Position = UDim2.new(0, newX, 0, newY)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if dragging then
            dragging = false
            UserInputService.MouseBehavior = Enum.MouseBehavior.Default
        end
    end)
end

-- Tooltip System --------------------------------------------------------------
local Tooltip = {}
function Tooltip.attach(gui, text)
    local tip
    gui.MouseEnter:Connect(function()
        if tip then tip:Destroy() end
        tip = Create.new("Frame", {
            Parent = gui,
            BackgroundColor3 = Theme.Background,
            BorderSizePixel = 0,
            Size = UDim2.new(0, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.XY,
            Position = UDim2.new(1, 10, 0, 0),
            CornerRadius = UDim.new(0, 6),
            Stroke = { Color = Theme.Border, Thickness = 1 },
            ZIndex = 100,
        })
        local label = Create.new("TextLabel", {
            Parent = tip,
            BackgroundTransparency = 1,
            Font = Theme.Font,
            Text = text,
            TextColor3 = Theme.Text,
            TextSize = 12,
            Size = UDim2.new(0, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.XY,
            Padding = { PaddingLeft = 8, PaddingRight = 8, PaddingTop = 6, PaddingBottom = 6 },
        })
        tip.BackgroundTransparency = 1
        TweenUtil.play(tip, { BackgroundTransparency = 0.1 })
    end)
    gui.MouseLeave:Connect(function()
        if tip then
            TweenUtil.play(tip, { BackgroundTransparency = 1 })
            task.delay(0.2, function()
                if tip then tip:Destroy() end
            end)
        end
    end)
end

