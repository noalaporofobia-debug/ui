    resetBtn.MouseButton1Click:Connect(reset)
    local c = { Frame = f, Start = start, Stop = stop, Reset = reset, Destroy = function() stop(); f:Destroy() end, Options = opts }
    return ComponentBase.new(c, "Timer", opts.WindowTitle, opts.TabName, opts.SectionName, opts.Name or opts.Text)
