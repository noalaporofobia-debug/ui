-- Button ----------------------------------------------------------------------
local Button = {}
Button.__index = Button

local STYLE_COLORS = {
	Default = Theme.Surface,
	Primary = Theme.Accent,
	Danger = Theme.Danger,
}
local STYLE_HOVER = {
	Default = Theme.SurfaceHover,
	Primary = Theme.AccentDark,
	Danger = Color3.fromRGB(180, 40, 40),
}

function Button.new(parent, options)
	local self = setmetatable({}, Button)
	local style = options.Style or "Default"
	local base = STYLE_COLORS[style]
	local hover = STYLE_HOVER[style]

	self.Frame = Create.new("Frame", {
		Name = "ButtonRow",
		Parent = parent,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, Theme.ItemHeight),
	})

	self.Button = Create.new("TextButton", {
		Name = options.Name or "Button",
		Parent = self.Frame,
		BackgroundColor3 = base,
		AutoButtonColor = false,
		Font = Theme.FontBold,
		Text = options.Name or "Button",
		TextColor3 = Theme.Text,
		TextSize = 13,
		Size = UDim2.fromScale(1, 1),
		CornerRadius = UDim.new(0, 4),
	})

	TweenUtil.bindHover(self.Button, base, hover)

	self.Button.MouseButton1Click:Connect(function()
		TweenUtil.play(self.Button, { Size = UDim2.new(0.95, 0, 0.9, 0) }, 0.05)
		TweenUtil.play(self.Button, { Size = UDim2.fromScale(1, 1) }, 0.1)
		if options.Callback then options.Callback() end
	end)

	if options.Tooltip then
		Tooltip.attach(self.Button, options.Tooltip)
	end

	return self
end

function Button:SetText(text)
	self.Button.Text = text
end

function Button:Destroy()
	self.Frame:Destroy()
end

