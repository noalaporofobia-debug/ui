		Position = self.Value and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9),
		Size = UDim2.fromOffset(self.Value and 20 or 18, self.Value and 20 or 18)
	})
	TweenUtil.play(self.Knob, { Size = UDim2.fromOffset(18, 18) }, 0.1, Enum.EasingStyle.Bounce)
	if self.Callback then self.Callback(self.Value) end
end

