local Timer = {}
function Timer:Create(parent, opts)
    local f = Create("Frame", {Parent=parent, BackgroundTransparency=1, Size=UDim2.new(1,0,0,Theme.ItemHeight)})
    local label = Create("TextLabel", {Parent=f, BackgroundTransparency=1, Font=Theme.Font, Text=opts.Text or L"Timer", TextColor3=Theme.Text, TextSize=14, TextXAlignment=Enum.TextXAlignment.Left, Size=UDim2.new(0.5,0,1,0)})
    local timeLabel = Create("TextLabel", {Parent=f, BackgroundTransparency=1, Font=Theme.FontBold, Text="0:00", TextColor3=Theme.Accent, TextSize=18, TextXAlignment=Enum.TextXAlignment.Right, Size=UDim2.new(0.5,-4,1,0), Position=UDim2.new(0.5,4,0,0)})
    local duration = opts.Duration or 10
    local remaining = duration
    local running = false
    local timerConn
    local function updateDisplay()
        local mins = math.floor(remaining/60)
        local secs = math.floor(remaining%60)
        timeLabel.Text = string.format("%d:%02d", mins, secs)
    end
    updateDisplay()
    local function start()
        if running then return end
        running = true
        timerConn = RunService.Heartbeat:Connect(function(dt)
            remaining = math.max(0, remaining - dt)
            updateDisplay()
            if remaining <= 0 then
                running = false; timerConn:Disconnect()
                if opts.Callback then opts.Callback() end
            end
        end)
    end
    local function stop()
        if timerConn then timerConn:Disconnect() end
        running = false
    end
    local function reset()
        stop()
        remaining = duration; updateDisplay()
    end
    -- Start button
    local startBtn = Create("TextButton", {Parent=f, BackgroundColor3=Theme.Surface, AutoButtonColor=false, Font=Theme.Font, Text="▶", TextColor3=Theme.Text, TextSize=16, Size=UDim2.fromOffset(30,30), Position=UDim2.new(0.5, -60, 0.5, -15), Corner=UDim.new(0,4)})
