	return self.Value
end

function Toggle:Destroy()
	self.Frame:Destroy()
end

-- Slider ----------------------------------------------------------------------
local Slider = {}
Slider.__index = Slider

local function clamp(v, min, max) return math.max(min, math.min(max, v)) end
local function roundToIncrement(v, inc)
	if inc <= 0 then return v end
	return math.floor(v / inc + 0.5) * inc
end

function Slider.new(parent, options)
	local self = setmetatable({}, Slider)
	self.Min = options.Min or 0
	self.Max = options.Max or 100
	self.Increment = options.Increment or 1
	self.Value = clamp(roundToIncrement(options.Default or self.Min, self.Increment), self.Min, self.Max)
	self.Callback = options.Callback
	self.Dragging = false

	self.Frame = Create.new("Frame", {
		Name = "SliderRow",
		Parent = parent,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, Theme.ItemHeight + 8),
	})

	self.NameLabel = Create.new("TextLabel", {
		Name = "Name",
		Parent = self.Frame,
		BackgroundTransparency = 1,
		Font = Theme.Font,
		Text = options.Name or "Slider",
		TextColor3 = Theme.Text,
		TextSize = 13,
		TextXAlignment = Enum.TextXAlignment.Left,
		Size = UDim2.new(1, -48, 0, 18),
	})

	self.ValueLabel = Create.new("TextLabel", {
		Name = "Value",
		Parent = self.Frame,
		BackgroundTransparency = 1,
		Font = Theme.FontBold,
		Text = tostring(self.Value),
		TextColor3 = Theme.Accent,
		TextSize = 13,
		TextXAlignment = Enum.TextXAlignment.Right,
		Size = UDim2.new(0, 48, 0, 18),
		Position = UDim2.new(1, -48, 0, 0),
	})

	self.Track = Create.new("Frame", {
		Name = "Track",
		Parent = self.Frame,
		BackgroundColor3 = Theme.Background,
		BorderSizePixel = 0,
		Position = UDim2.fromOffset(0, 24),
		Size = UDim2.new(1, 0, 0, 8),
		CornerRadius = UDim.new(1, 0),
	})

	self.Fill = Create.new("Frame", {
		Name = "Fill",
		Parent = self.Track,
		BackgroundColor3 = Theme.Accent,
		BorderSizePixel = 0,
		Size = UDim2.new(0, 0, 1, 0),
		CornerRadius = UDim.new(1, 0),
	})

	self.Knob = Create.new("TextButton", {
		Name = "Knob",
		Parent = self.Track,
		BackgroundColor3 = Theme.Text,
		AutoButtonColor = false,
		Text = "",
		Size = UDim2.fromOffset(14, 14),
		Position = UDim2.new(0, -7, 0.5, -7),
		CornerRadius = UDim.new(1, 0),
	})

	self:_updateVisuals(false)

	local function startDrag(input)
		self.Dragging = true
		self:_setFromInput(input)
	end

	self.Knob.InputBegan:Connect(startDrag)
	self.Track.InputBegan:Connect(startDrag)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			self.Dragging = false
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if self.Dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			self:_setFromInput(input)
		end
	end)

	return self
end

function Slider:_ratio()
	if self.Max == self.Min then return 0 end
	return (self.Value - self.Min) / (self.Max - self.Min)
end

function Slider:_updateVisuals(animate)
	local ratio = self:_ratio()
	self.ValueLabel.Text = tostring(self.Value)
	local fillSize = UDim2.new(ratio, 0, 1, 0)
	local knobPos = UDim2.new(ratio, -7, 0.5, -7)
	if animate then
		TweenUtil.play(self.Fill, { Size = fillSize })
		TweenUtil.play(self.Knob, { Position = knobPos })
	else
		self.Fill.Size = fillSize
		self.Knob.Position = knobPos
	end
end

function Slider:_setFromInput(input)
	local track = self.Track
	local relative = (input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X
	relative = clamp(relative, 0, 1)
	local raw = self.Min + (self.Max - self.Min) * relative
	self:SetValue(raw)
end

function Slider:SetValue(value)
	local newVal = clamp(roundToIncrement(value, self.Increment), self.Min, self.Max)
	if newVal == self.Value then
		self:_updateVisuals(true)
		return
	end
	self.Value = newVal
	self:_updateVisuals(true)
	if self.Callback then self.Callback(self.Value) end
end

function Slider:GetValue()
	return self.Value
end

function Slider:Destroy()
	self.Frame:Destroy()
end

-- Dropdown --------------------------------------------------------------------
local Dropdown = {}
Dropdown.__index = Dropdown

function Dropdown.new(parent, options)
	local self = setmetatable({}, Dropdown)
	self.Options = options.Options or {}
	self.Callback = options.Callback
	self.Open = false
	self.Value = options.Default or self.Options[1]
	self.FilteredOptions = self.Options

	self.Frame = Create.new("Frame", {
		Name = "DropdownRow",
		Parent = parent,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, Theme.ItemHeight),
		ClipsDescendants = false,
	})

	self.NameLabel = Create.new("TextLabel", {
		Name = "Name",
		Parent = self.Frame,
		BackgroundTransparency = 1,
		Font = Theme.Font,
		Text = options.Name or "Dropdown",
		TextColor3 = Theme.Text,
		TextSize = 13,
		TextXAlignment = Enum.TextXAlignment.Left,
		Size = UDim2.new(0.45, 0, 1, 0),
	})

	self.Selector = Create.new("TextButton", {
		Name = "Selector",
		Parent = self.Frame,
		BackgroundColor3 = Theme.Background,
		AutoButtonColor = false,
		Font = Theme.Font,
		Text = self.Value or "Select",
		TextColor3 = Theme.Text,
		TextSize = 13,
		TextTruncate = Enum.TextTruncate.AtEnd,
		Size = UDim2.new(0.55, -4, 1, 0),
		Position = UDim2.new(0.45, 4, 0, 0),
		CornerRadius = UDim.new(0, 4),
	})

	self.List = Create.new("ScrollingFrame", {
		Name = "List",
		Parent = self.Frame,
		BackgroundColor3 = Theme.Surface,
		BorderSizePixel = 0,
		Position = UDim2.new(0.45, 4, 1, 4),
		Size = UDim2.new(0.55, -4, 0, 0),
		Visible = false,
		CanvasSize = UDim2.new(0, 0, 0, 0),
		ScrollBarThickness = Theme.ScrollbarThickness,
		ScrollBarImageColor3 = Theme.Accent,
		ZIndex = 10,
		CornerRadius = UDim.new(0, 4),
		Stroke = { Color = Theme.Border, Thickness = 1 },
	})

	self.SearchBox = Create.new("TextBox", {
		Name = "Search",
		Parent = self.List,
		BackgroundColor3 = Theme.Background,
		ClearTextOnFocus = false,
		Font = Theme.Font,
		PlaceholderText = "Search...",
		PlaceholderColor3 = Theme.Muted,
		Text = "",
		TextColor3 = Theme.Text,
		TextSize = 12,
		Size = UDim2.new(1, -8, 0, 24),
		Position = UDim2.fromOffset(4, 4),
		CornerRadius = UDim.new(0, 4),
		Visible = #self.Options > 8, -- show only if many options
	})

	self.ListContent = Create.new("Frame", {
		Name = "Content",
		Parent = self.List,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		ListLayout = { Padding = 2 },
		Padding = {
			PaddingTop = self.SearchBox.Visible and 32 or 4,
			PaddingBottom = 4,
			PaddingLeft = 4,
			PaddingRight = 4,
		},
	})

	-- Populate dropdown
	local function renderOptions(filterText)
		-- Clear existing children except layout
		for _, child in ipairs(self.ListContent:GetChildren()) do
			if child:IsA("TextButton") then child:Destroy() end
		end
		filterText = filterText and filterText:lower() or ""
		local displayed = {}
		for _, opt in ipairs(self.Options) do
			if filterText == "" or tostring(opt):lower():find(filterText) then
				table.insert(displayed, opt)
			end
		end
		self.FilteredOptions = displayed
		for _, opt in ipairs(displayed) do
			local btn = Create.new("TextButton", {
				Parent = self.ListContent,
				BackgroundColor3 = Theme.Background,
				AutoButtonColor = false,
				Font = Theme.Font,
				Text = tostring(opt),
				TextColor3 = Theme.Text,
				TextSize = 13,
				Size = UDim2.new(1, 0, 0, 28),
				CornerRadius = UDim.new(0, 4),
			})
			TweenUtil.bindHover(btn, Theme.Background, Theme.SurfaceHover)
			btn.MouseButton1Click:Connect(function()
				self:SetValue(opt)
				self:Close()
			end)
		end
		-- adjust list size
		local layout = self.ListContent:FindFirstChildOfClass("UIListLayout")
		if layout then
			layout:GetPropertyChangedSignal("AbsoluteContentSize"):Wait()
			local contentHeight = layout.AbsoluteContentSize.Y + (self.SearchBox.Visible and 36 or 8)
			local maxHeight = 160
			local height = math.min(contentHeight, maxHeight)
			self.List.Size = UDim2.new(0.55, -4, 0, height)
			self.List.CanvasSize = UDim2.fromOffset(0, contentHeight)
		end
	end

	renderOptions(nil)

	self.SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
		renderOptions(self.SearchBox.Text)
	end)

	self.Selector.MouseButton1Click:Connect(function()
		if self.Open then self:Close() else self:OpenList() end
	end)

	TweenUtil.bindHover(self.Selector, Theme.Background, Theme.SurfaceHover)

	-- Close when clicking outside
	local function closeOutside(input)
		if self.Open and input.UserInputType == Enum.UserInputType.MouseButton1 then
			local pos = input.Position
			if not (self.List.AbsolutePosition.X <= pos.X and pos.X <= self.List.AbsolutePosition.X + self.List.AbsoluteSize.X
				and self.List.AbsolutePosition.Y <= pos.Y and pos.Y <= self.List.AbsolutePosition.Y + self.List.AbsoluteSize.Y)
				and not (self.Selector.AbsolutePosition.X <= pos.X and pos.X <= self.Selector.AbsolutePosition.X + self.Selector.AbsoluteSize.X
				and self.Selector.AbsolutePosition.Y <= pos.Y and pos.Y <= self.Selector.AbsolutePosition.Y + self.Selector.AbsoluteSize.Y) then
				self:Close()
			end
		end
	end
	UserInputService.InputBegan:Connect(closeOutside)

	return self
end

function Dropdown:OpenList()
	self.Open = true
	self.List.Visible = true
	-- render options again to ensure search is updated
	local searchText = self.SearchBox.Text
	self.SearchBox.Text = searchText
end

function Dropdown:Close()
	self.Open = false
	self.List.Visible = false
end

function Dropdown:SetValue(value)
	self.Value = value
	self.Selector.Text = tostring(value)
	if self.Callback then self.Callback(value) end
end

function Dropdown:GetValue()
	return self.Value
end

function Dropdown:Destroy()
	self.Frame:Destroy()
end

-- Textbox ---------------------------------------------------------------------
local Textbox = {}
Textbox.__index = Textbox

function Textbox.new(parent, options)
	local self = setmetatable({}, Textbox)
	self.Callback = options.Callback
	self.CallbackOn = options.CallbackOn or "FocusLost"

	self.Frame = Create.new("Frame", {
		Name = "TextboxRow",
		Parent = parent,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, Theme.ItemHeight),
	})

	self.NameLabel = Create.new("TextLabel", {
		Name = "Name",
		Parent = self.Frame,
		BackgroundTransparency = 1,
		Font = Theme.Font,
		Text = options.Name or "Textbox",
		TextColor3 = Theme.Text,
		TextSize = 13,
		TextXAlignment = Enum.TextXAlignment.Left,
		Size = UDim2.new(0.45, 0, 1, 0),
	})

	self.Input = Create.new("TextBox", {
		Name = "Input",
		Parent = self.Frame,
		BackgroundColor3 = Theme.Background,
		ClearTextOnFocus = false,
		Font = Theme.Font,
		PlaceholderText = options.Placeholder or "",
		PlaceholderColor3 = Theme.Muted,
		Text = options.Default or "",
		TextColor3 = Theme.Text,
		TextSize = 13,
		TextXAlignment = Enum.TextXAlignment.Left,
		Size = UDim2.new(0.55, -4, 1, 0),
		Position = UDim2.new(0.45, 4, 0, 0),
		CornerRadius = UDim.new(0, 4),
		Padding = { PaddingLeft = 8, PaddingRight = 8 },
	})

	if options.MaxLength then
		self.Input:GetPropertyChangedSignal("Text"):Connect(function()
			if #self.Input.Text > options.MaxLength then
				self.Input.Text = self.Input.Text:sub(1, options.MaxLength)
			end
		end)
	end

	self.Input.FocusLost:Connect(function(enterPressed)
		if self.CallbackOn == "FocusLost" and self.Callback then
			self.Callback(self.Input.Text, enterPressed)
		end
		TweenUtil.play(self.Input, { BackgroundColor3 = Theme.Background })
	end)

	self.Input:GetPropertyChangedSignal("Text"):Connect(function()
		if self.CallbackOn == "Changed" and self.Callback then
			self.Callback(self.Input.Text, false)
		end
	end)

	self.Input.Focused:Connect(function()
		TweenUtil.play(self.Input, { BackgroundColor3 = Theme.Surface })
	end)

	return self
end

function Textbox:SetText(text)
	self.Input.Text = text
end

function Textbox:GetText()
	return self.Input.Text
end

function Textbox:Destroy()
	self.Frame:Destroy()
end

-- Section ---------------------------------------------------------------------
local Section = {}
Section.__index = Section

function Section.new(tab, options)
	local self = setmetatable({}, Section)
	self.Tab = tab
	self.Collapsed = false
	self.Collapsible = options.Collapsible == true

	self.Frame = Create.new("Frame", {
		Name = options.Name or "Section",
		Parent = tab.Content,
		BackgroundColor3 = Theme.Surface,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		CornerRadius = Theme.CornerRadius,
	})

	self.Header = Create.new("TextButton", {
		Name = "Header",
		Parent = self.Frame,
		BackgroundTransparency = 1,
		AutoButtonColor = false,
		Font = Theme.FontBold,
		Text = options.Name or "Section",
		TextColor3 = Theme.Text,
		TextSize = 13,
		TextXAlignment = Enum.TextXAlignment.Left,
		Size = UDim2.new(1, 0, 0, Theme.SectionHeaderHeight),
	})

	Create.new("UIPadding", { Parent = self.Header,
		PaddingLeft = UDim.new(0, Theme.Padding),
		PaddingRight = UDim.new(0, Theme.Padding),
	})

	self.Body = Create.new("Frame", {
		Name = "Body",
		Parent = self.Frame,
		BackgroundTransparency = 1,
		Position = UDim2.fromOffset(0, Theme.SectionHeaderHeight),
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		ListLayout = { Padding = 6 },
		Padding = {
			PaddingLeft = Theme.Padding,
			PaddingRight = Theme.Padding,
			PaddingBottom = Theme.Padding,
		},
	})

	if self.Collapsible then
		self.Header.Text = "▼ " .. self.Header.Text
		self.Header.MouseButton1Click:Connect(function()
			self:ToggleCollapse()
		end)
	end

	return self
end

function Section:ToggleCollapse()
	self.Collapsed = not self.Collapsed
	self.Body.Visible = not self.Collapsed
	local prefix = self.Collapsed and "▶ " or "▼ "
	local title = self.Header.Text:gsub("^[▶▼] ", "")
	self.Header.Text = prefix .. title

	if self.Collapsed then
		TweenUtil.play(self.Frame, { Size = UDim2.new(1, 0, 0, Theme.SectionHeaderHeight) }, 0.2)
	else
		self.Frame.AutomaticSize = Enum.AutomaticSize.Y
		TweenUtil.play(self.Frame, { Size = UDim2.new(1, 0, 0, 0) }, 0.2) -- reset
		task.wait(0.2)
		self.Frame.AutomaticSize = Enum.AutomaticSize.Y
	end
end

function Section:AddButton(options) return Button.new(self.Body, options) end
function Section:AddToggle(options) return Toggle.new(self.Body, options) end
function Section:AddSlider(options) return Slider.new(self.Body, options) end
function Section:AddDropdown(options) return Dropdown.new(self.Body, options) end
function Section:AddTextbox(options) return Textbox.new(self.Body, options) end
function Section:AddLabel(options) return Label.new(self.Body, options) end

-- Tab -------------------------------------------------------------------------
local Tab = {}
Tab.__index = Tab

function Tab.new(window, options)
	local self = setmetatable({}, Tab)
	self.Window = window
	self.Sections = {}
	self.Visible = false

	self.Button = Create.new("TextButton", {
		Name = options.Name or "Tab",
		Parent = window.TabBar,
		BackgroundColor3 = Theme.Surface,
		AutoButtonColor = false,
		Font = Theme.Font,
		Text = options.Name or "Tab",
		TextColor3 = Theme.Muted,
		TextSize = 13,
		Size = UDim2.fromOffset(90, Theme.TabBarHeight - 8),
		CornerRadius = UDim.new(0, 4),
	})

	self.Page = Create.new("ScrollingFrame", {
		Name = (options.Name or "Tab") .. "Page",
		Parent = window.ContentArea,
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.fromScale(1, 1),
		CanvasSize = UDim2.new(0, 0, 0, 0),
		ScrollBarThickness = Theme.ScrollbarThickness,
		ScrollBarImageColor3 = Theme.Accent,
		ClipsDescendants = false,
		Visible = false,
	})

	self.Content = Create.new("Frame", {
		Name = "Content",
		Parent = self.Page,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		ListLayout = { Padding = Theme.Padding },
		Padding = {
			PaddingLeft = Theme.Padding,
			PaddingRight = Theme.Padding,
			PaddingTop = Theme.Padding,
			PaddingBottom = Theme.Padding,
		},
	})

	local layout = self.Content:FindFirstChildOfClass("UIListLayout")
	layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		self.Page.CanvasSize = UDim2.fromOffset(0, layout.AbsoluteContentSize.Y + Theme.Padding * 2)
	end)

	return self
end

function Tab:Show()
	self.Visible = true
	self.Page.Visible = true
end

function Tab:Hide()
	self.Visible = false
	self.Page.Visible = false
end

function Tab:AddSection(options)
	local section = Section.new(self, options)
	table.insert(self.Sections, section)
	return section
end

-- Window ----------------------------------------------------------------------
local Window = {}
Window.__index = Window

function Window.new(options)
	local self = setmetatable({}, Window)
	self.Tabs = {}
	self.ActiveTab = nil
	self.Minimized = false

	local playerGui = Players.LocalPlayer:WaitForChild("PlayerGui")
	local windowName = options.Name or "UIWindow"
	local windowTitle = options.Title or windowName
	local windowSize = options.Size or UDim2.fromOffset(420, 540)
	local windowPosition = options.Position or UDim2.new(0.297, 0, 0.112, 0)

	self.ScreenGui = Create.new("ScreenGui", {
		Name = windowName,
		ResetOnSpawn = false,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
		Parent = playerGui,
	})

	self.Frame = Create.new("Frame", {
		Name = "Main",
		Parent = self.ScreenGui,
		BackgroundColor3 = Theme.Background,
		BorderSizePixel = 0,
		Size = windowSize,
		Position = windowPosition,
		Active = true,
		ClipsDescendants = true,
		CornerRadius = Theme.CornerRadius,
		Stroke = { Color = Theme.Border, Thickness = 1 },
	})

	self.TitleBar = Create.new("Frame", {
		Name = "TitleBar",
		Parent = self.Frame,
		BackgroundColor3 = Theme.Surface,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, Theme.TitleBarHeight),
	})

	self.TitleLabel = Create.new("TextLabel", {
		Name = "Title",
		Parent = self.TitleBar,
		BackgroundTransparency = 1,
		Font = Theme.FontBold,
		Text = windowTitle,
		TextColor3 = Theme.Text,
		TextSize = 14,
		TextXAlignment = Enum.TextXAlignment.Left,
		Position = UDim2.fromOffset(Theme.Padding, 0),
		Size = UDim2.new(1, -(Theme.TitleBarHeight*2 + Theme.Padding*2), 1, 0),
	})

	-- Minimize button
	self.MinButton = Create.new("TextButton", {
		Name = "Minimize",
		Parent = self.TitleBar,
		BackgroundColor3 = Theme.Surface,
		AutoButtonColor = false,
		Font = Theme.FontBold,
		Text = "_",
		TextColor3 = Theme.Muted,
		TextSize = 14,
		Size = UDim2.fromOffset(Theme.TitleBarHeight, Theme.TitleBarHeight),
		Position = UDim2.new(1, -Theme.TitleBarHeight*2, 0, 0),
	})

	self.CloseButton = Create.new("TextButton", {
		Name = "Close",
		Parent = self.TitleBar,
		BackgroundColor3 = Theme.Surface,
		AutoButtonColor = false,
		Font = Theme.FontBold,
		Text = "X",
		TextColor3 = Theme.Muted,
		TextSize = 14,
		Size = UDim2.fromOffset(Theme.TitleBarHeight, Theme.TitleBarHeight),
		Position = UDim2.new(1, -Theme.TitleBarHeight, 0, 0),
	})

	self.TabBar = Create.new("Frame", {
		Name = "TabBar",
		Parent = self.Frame,
		BackgroundColor3 = Theme.Background,
		BorderSizePixel = 0,
		Position = UDim2.fromOffset(0, Theme.TitleBarHeight),
		Size = UDim2.new(1, 0, 0, Theme.TabBarHeight),
		ListLayout = {
			FillDirection = Enum.FillDirection.Horizontal,
			Padding = 4,
			HorizontalAlignment = Enum.HorizontalAlignment.Left,
		},
		Padding = {
			PaddingLeft = Theme.Padding,
			PaddingRight = Theme.Padding,
			PaddingTop = 4,
			PaddingBottom = 4,
		},
	})

	self.ContentArea = Create.new("Frame", {
		Name = "ContentArea",
		Parent = self.Frame,
		BackgroundTransparency = 1,
		Position = UDim2.fromOffset(0, Theme.TitleBarHeight + Theme.TabBarHeight),
		Size = UDim2.new(1, 0, 1, -(Theme.TitleBarHeight + Theme.TabBarHeight)),
	})

	Drag.enable(self.TitleBar, self.Frame, true)

	-- Minimize behavior
	self.MinButton.MouseEnter:Connect(function()
		TweenUtil.play(self.MinButton, { TextColor3 = Theme.Text })
	end)
	self.MinButton.MouseLeave:Connect(function()
		TweenUtil.play(self.MinButton, { TextColor3 = Theme.Muted })
	end)
	self.MinButton.MouseButton1Click:Connect(function()
		self:ToggleMinimize()
	end)

	self.CloseButton.MouseEnter:Connect(function()
		TweenUtil.play(self.CloseButton, { TextColor3 = Theme.Danger })
	end)
	self.CloseButton.MouseLeave:Connect(function()
		TweenUtil.play(self.CloseButton, { TextColor3 = Theme.Muted })
	end)
	self.CloseButton.MouseButton1Click:Connect(function()
		self:Destroy()
	end)

	-- Keyboard shortcuts
	UserInputService.InputBegan:Connect(function(input, gameProcessed)
		if gameProcessed then return end
		if input.KeyCode == Enum.KeyCode.Escape then
			self:Destroy()
		elseif input.KeyCode == Enum.KeyCode.M then
			self:ToggleMinimize()
		end
	end)

	return self
end

function Window:SetTitle(title)
	self.TitleLabel.Text = title
end

function Window:ToggleMinimize()
	self.Minimized = not self.Minimized
	local height = self.Minimized and Theme.TitleBarHeight else UDim2.new(1, 0)
	TweenUtil.play(self.Frame, { Size = UDim2.new(self.Frame.Size.X.Scale, self.Frame.Size.X.Offset, 0, height) }, 0.2)
end

function Window:Destroy()
	TweenUtil.play(self.Frame, { BackgroundTransparency = 1, Size = self.Frame.Size - UDim2.fromOffset(20,20) }, 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
	task.delay(0.2, function()
		self.ScreenGui:Destroy()
	end)
end

function Window:_setActiveTab(tab)
	if self.ActiveTab then self.ActiveTab:Hide() end
	self.ActiveTab = tab
	tab:Show()
	for _, otherTab in ipairs(self.Tabs) do
		local isActive = (otherTab == tab)
		TweenUtil.play(otherTab.Button, {
			BackgroundColor3 = isActive and Theme.Accent or Theme.Surface,
			TextColor3 = isActive and Theme.Text or Theme.Muted,
		})
	end
end

function Window:AddTab(options)
	local tab = Tab.new(self, options)
	table.insert(self.Tabs, tab)
	if not self.ActiveTab then self:_setActiveTab(tab) end
	tab.Button.MouseButton1Click:Connect(function()
		self:_setActiveTab(tab)
	end)
	return tab
end

-- Notify ----------------------------------------------------------------------
local Notify = {}
local notifyContainer
local activeNotifications = {}

local function getNotifyContainer()
	if notifyContainer and notifyContainer.Parent then return notifyContainer end
	local playerGui = Players.LocalPlayer:WaitForChild("PlayerGui")
	notifyContainer = Create.new("ScreenGui", {
		Name = "UINotifications",
		ResetOnSpawn = false,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
		Parent = playerGui,
	})
	Create.new("Frame", {
		Name = "Stack",
		Parent = notifyContainer,
		BackgroundTransparency = 1,
		Position = UDim2.new(1, -Theme.Padding, 0, Theme.Padding),
		Size = UDim2.fromOffset(320, 0),
		AnchorPoint = Vector2.new(1, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		ListLayout = { Padding = 8, HorizontalAlignment = Enum.HorizontalAlignment.Right },
	})
	return notifyContainer
end

local function repositionNotifications()
	for i, item in ipairs(activeNotifications) do
		item.Frame.LayoutOrder = i
	end
end

function Notify.show(options)
	options = options or {}
	local gui = getNotifyContainer()
	local stack = gui:FindFirstChild("Stack")
	local duration = options.Duration or 4

	if #activeNotifications >= (Theme.NotificationMax or 5) then
		local oldest = table.remove(activeNotifications, 1)
		oldest.Frame:Destroy()
	end

	local frame = Create.new("Frame", {
		Name = "Notification",
		Parent = stack,
		BackgroundColor3 = Theme.Surface,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(300, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		CornerRadius = Theme.CornerRadius,
		Stroke = { Color = Theme.Accent, Thickness = 1 },
	})

	local title = Create.new("TextLabel", {
		Name = "Title",
		Parent = frame,
		BackgroundTransparency = 1,
		Font = Theme.FontBold,
		Text = options.Title or "Notice",
		TextColor3 = Theme.Text,
		TextSize = 14,
		TextXAlignment = Enum.TextXAlignment.Left,
		Size = UDim2.new(1, -Theme.Padding*2, 0, 20),
		Position = UDim2.fromOffset(Theme.Padding, Theme.Padding),
	})

	local content = Create.new("TextLabel", {
		Name = "Content",
		Parent = frame,
		BackgroundTransparency = 1,
		Font = Theme.Font,
		Text = options.Content or "",
		TextColor3 = Theme.Muted,
		TextSize = 13,
		TextWrapped = true,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextYAlignment = Enum.TextYAlignment.Top,
		Size = UDim2.new(1, -Theme.Padding*2, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		Position = UDim2.fromOffset(Theme.Padding, Theme.Padding + 22),
	})

	local progressTrack = Create.new("Frame", {
		Name = "ProgressTrack",
		Parent = frame,
		BackgroundColor3 = Theme.Background,
		BorderSizePixel = 0,
		Size = UDim2.new(1, -Theme.Padding*2, 0, 3),
		Position = UDim2.new(0, Theme.Padding, 1, -(Theme.Padding + 3)),
		CornerRadius = UDim.new(1, 0),
	})

	local progressFill = Create.new("Frame", {
		Name = "ProgressFill",
		Parent = progressTrack,
		BackgroundColor3 = Theme.Accent,
		BorderSizePixel = 0,
		Size = UDim2.fromScale(1, 1),
		CornerRadius = UDim.new(1, 0),
	})

	-- Close button on notification
	local closeBtn = Create.new("TextButton", {
		Name = "CloseBtn",
		Parent = frame,
		BackgroundTransparency = 1,
		Font = Theme.FontBold,
		Text = "×",
		TextColor3 = Theme.Muted,
		TextSize = 18,
		Size = UDim2.fromOffset(20,20),
		Position = UDim2.new(1, -24, 0, 2),
		ZIndex = 2,
	})
	closeBtn.MouseButton1Click:Connect(function()
		frame:Destroy()
		for i, item in ipairs(activeNotifications) do
			if item.Frame == frame then
				table.remove(activeNotifications, i)
				break
			end
		end
		repositionNotifications()
	end)

	local bottomPadding = Instance.new("UIPadding")
	bottomPadding.PaddingBottom = UDim.new(0, Theme.Padding + 8)
	bottomPadding.Parent = frame

	local item = { Frame = frame }
	table.insert(activeNotifications, item)
	repositionNotifications()

	-- Entrance animation
	frame.BackgroundTransparency = 1
	title.TextTransparency = 1
	content.TextTransparency = 1
	frame.Position = UDim2.new(1, 20, 0, frame.Position.Y.Offset)
	TweenUtil.play(frame, { Position = UDim2.new(1, 0, 0, frame.Position.Y.Offset), BackgroundTransparency = 0 })
	TweenUtil.play(title, { TextTransparency = 0 })
	TweenUtil.play(content, { TextTransparency = 0 })

	if duration > 0 then
		TweenUtil.play(progressFill, { Size = UDim2.fromScale(0, 1) }, duration, Enum.EasingStyle.Linear)
		task.delay(duration, function()
			if not frame.Parent then return end
			local fade = TweenUtil.play(frame, { BackgroundTransparency = 1 }, 0.2)
			TweenUtil.play(title, { TextTransparency = 1 })
			TweenUtil.play(content, { TextTransparency = 1 })
			fade.Completed:Wait()
			frame:Destroy()
			for i, item in ipairs(activeNotifications) do
				if item.Frame == frame then
					table.remove(activeNotifications, i)
					break
				end
			end
			repositionNotifications()
		end)
	end

	return {
		Destroy = function()
			if frame.Parent then frame:Destroy() end
		end,
		SetTitle = function(text) title.Text = text end,
		SetContent = function(text) content.Text = text end,
	}
end

