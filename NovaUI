	self.Track = Create.new("TextButton", {
		Name = "Track",
		Parent = self.Frame,
		BackgroundColor3 = self.Value and Theme.Accent or Theme.Background,
		AutoButtonColor = false,
		Text = "",
		Size = UDim2.fromOffset(44, 22),
		Position = UDim2.new(1, -44, 0.5, -11),
