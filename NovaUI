    if self.Collapsible then
        self.Header.MouseButton1Click:Connect(function()
            self:ToggleCollapse()
        end)
    end
    return self
end
function Section:ToggleCollapse()
    self.Collapsed = not self.Collapsed
    self.Body.Visible = not self.Collapsed
    local prefix = self.Collapsed and "▶ " or "▼ "
    local title = self.Header.Text:gsub("^[▶▼] ", "")
    self.Header.Text = prefix .. title
end
function Section:AddButton(options) return Button.new(self.Body, options) end
function Section:AddToggle(options) return Toggle.new(self.Body, options) end
function Section:AddSlider(options) return Slider.new(self.Body, options) end
function Section:AddDropdown(options) return Dropdown.new(self.Body, options) end
function Section:AddTextbox(options) return Textbox.new(self.Body, options) end
function Section:AddLabel(options) return Label.new(self.Body, options) end

-- Tab ------------------------------------------------------------------------
local Tab = {}
Tab.__index = Tab
function Tab.new(window, options)
    local self = setmetatable({}, Tab)
    self.Window = window
    self.Sections = {}
    self.Visible = false

    self.Button = Create.new("TextButton", {
        Name = options.Name or "Tab",
        Parent = window.TabBar,
        BackgroundColor3 = Theme.Surface,
        AutoButtonColor = false,
        Font = Theme.Font,
        Text = options.Name or "Tab",
        TextColor3 = Theme.Muted,
        TextSize = 13,
        Size = UDim2.fromOffset(100, Theme.TabBarHeight - 10),
        CornerRadius = UDim.new(0, 6),
    })
    self.Page = Create.new("ScrollingFrame", {
        Name = (options.Name or "Tab") .. "Page",
        Parent = window.ContentArea,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Size = UDim2.fromScale(1, 1),
        CanvasSize = UDim2.new(0, 0, 0, 0),
        ScrollBarThickness = Theme.ScrollbarThickness,
        ScrollBarImageColor3 = Theme.Accent,
        ClipsDescendants = false,
        Visible = false,
    })
    self.Content = Create.new("Frame", {
        Name = "Content",
        Parent = self.Page,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        ListLayout = { Padding = Theme.Padding },
        Padding = {
            PaddingLeft = Theme.Padding,
            PaddingRight = Theme.Padding,
            PaddingTop = Theme.Padding,
            PaddingBottom = Theme.Padding,
        },
    })
    local layout = self.Content:FindFirstChildOfClass("UIListLayout")
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        self.Page.CanvasSize = UDim2.fromOffset(0, layout.AbsoluteContentSize.Y + Theme.Padding * 2)
    end)
    return self
end
function Tab:Show()
    self.Visible = true
    self.Page.Visible = true
end
function Tab:Hide()
    self.Visible = false
    self.Page.Visible = false
end
function Tab:AddSection(options)
    local section = Section.new(self, options)
    table.insert(self.Sections, section)
    return section
end

-- Window ----------------------------------------------------------------------
local Window = {}
Window.__index = Window
function Window.new(options)
    local self = setmetatable({}, Window)
    self.Tabs = {}
    self.ActiveTab = nil
    self.Minimized = false

    local playerGui = Players.LocalPlayer:WaitForChild("PlayerGui")
    local windowName = options.Name or "NovaUI"
    local windowTitle = options.Title or windowName
    local windowSize = options.Size or UDim2.fromOffset(450, 560)
    local windowPos = options.Position or UDim2.new(0.3, 0, 0.1, 0)

    self.ScreenGui = Create.new("ScreenGui", {
        Name = windowName,
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        Parent = playerGui,
    })
    self.Frame = Create.new("Frame", {
        Name = "Main",
        Parent = self.ScreenGui,
        BackgroundColor3 = Theme.Background,
        BorderSizePixel = 0,
        Size = windowSize,
        Position = windowPos,
        Active = true,
        ClipsDescendants = true,
        CornerRadius = Theme.CornerRadius,
        Stroke = { Color = Theme.Border, Thickness = 1.5 },
    })
    -- Sombra sutil
    local shadow = Create.new("Frame", {
        Name = "Shadow",
        Parent = self.Frame,
        BackgroundColor3 = Color3.new(0,0,0),
        BackgroundTransparency = 0.85,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 6, 1, 6),
        Position = UDim2.new(0, -3, 0, -3),
        ZIndex = -1,
        CornerRadius = Theme.CornerRadius,
    })
    self.TitleBar = Create.new("Frame", {
        Name = "TitleBar",
        Parent = self.Frame,
        BackgroundColor3 = Theme.Surface,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, Theme.TitleBarHeight),
    })
    self.TitleLabel = Create.new("TextLabel", {
        Name = "Title",
        Parent = self.TitleBar,
        BackgroundTransparency = 1,
        Font = Theme.FontBold,
        Text = windowTitle,
        TextColor3 = Theme.Text,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left,
        Position = UDim2.fromOffset(Theme.Padding, 0),
        Size = UDim2.new(1, -(Theme.TitleBarHeight*2 + Theme.Padding*2), 1, 0),
    })
    self.MinButton = Create.new("TextButton", {
        Name = "Minimize",
        Parent = self.TitleBar,
        BackgroundColor3 = Theme.Surface,
        AutoButtonColor = false,
        Font = Theme.FontBold,
        Text = "—",
        TextColor3 = Theme.Muted,
        TextSize = 14,
        Size = UDim2.fromOffset(Theme.TitleBarHeight, Theme.TitleBarHeight),
        Position = UDim2.new(1, -Theme.TitleBarHeight*2, 0, 0),
    })
    self.CloseButton = Create.new("TextButton", {
        Name = "Close",
        Parent = self.TitleBar,
        BackgroundColor3 = Theme.Surface,
        AutoButtonColor = false,
        Font = Theme.FontBold,
        Text = "✕",
        TextColor3 = Theme.Muted,
        TextSize = 14,
        Size = UDim2.fromOffset(Theme.TitleBarHeight, Theme.TitleBarHeight),
        Position = UDim2.new(1, -Theme.TitleBarHeight, 0, 0),
    })
    self.TabBar = Create.new("Frame", {
        Name = "TabBar",
        Parent = self.Frame,
        BackgroundColor3 = Theme.Background,
        BorderSizePixel = 0,
        Position = UDim2.fromOffset(0, Theme.TitleBarHeight),
        Size = UDim2.new(1, 0, 0, Theme.TabBarHeight),
        ListLayout = {
            FillDirection = Enum.FillDirection.Horizontal,
            Padding = 6,
            HorizontalAlignment = Enum.HorizontalAlignment.Left,
        },
        Padding = {
            PaddingLeft = Theme.Padding,
            PaddingRight = Theme.Padding,
            PaddingTop = 6,
            PaddingBottom = 6,
        },
    })
    self.ContentArea = Create.new("Frame", {
        Name = "ContentArea",
        Parent = self.Frame,
        BackgroundTransparency = 1,
        Position = UDim2.fromOffset(0, Theme.TitleBarHeight + Theme.TabBarHeight),
        Size = UDim2.new(1, 0, 1, -(Theme.TitleBarHeight + Theme.TabBarHeight)),
    })

    Drag.enable(self.TitleBar, self.Frame)

    -- Botones de la barra de título
    self.MinButton.MouseEnter:Connect(function()
        TweenUtil.play(self.MinButton, { TextColor3 = Theme.Text })
    end)
    self.MinButton.MouseLeave:Connect(function()
        TweenUtil.play(self.MinButton, { TextColor3 = Theme.Muted })
    end)
    self.MinButton.MouseButton1Click:Connect(function()
        self:ToggleMinimize()
    end)
    self.CloseButton.MouseEnter:Connect(function()
        TweenUtil.play(self.CloseButton, { TextColor3 = Theme.Danger })
    end)
    self.CloseButton.MouseLeave:Connect(function()
        TweenUtil.play(self.CloseButton, { TextColor3 = Theme.Muted })
    end)
    self.CloseButton.MouseButton1Click:Connect(function()
        self:Destroy()
    end)

    -- Atajos de teclado
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == Enum.KeyCode.Escape then
            self:Destroy()
        elseif input.KeyCode == Enum.KeyCode.M then
            self:ToggleMinimize()
        end
    end)

    -- Animación de entrada
    self.Frame.BackgroundTransparency = 1
    self.Frame.Size = windowSize - UDim2.fromOffset(20, 20)
    self.Frame.Position = windowPos + UDim2.fromOffset(10, 10)
    TweenUtil.play(self.Frame, {
        BackgroundTransparency = 0,
        Size = windowSize,
        Position = windowPos
    }, 0.3, Enum.EasingStyle.Back)

    return self
end
function Window:SetTitle(title)
    self.TitleLabel.Text = title
end
function Window:ToggleMinimize()
    self.Minimized = not self.Minimized
    self.ContentArea.Visible = not self.Minimized
    self.TabBar.Visible = not self.Minimized
    self.MinButton.Text = self.Minimized and "□" or "—"
end
function Window:Destroy()
    TweenUtil.play(self.Frame, {
        BackgroundTransparency = 1,
        Size = self.Frame.Size - UDim2.fromOffset(20, 20),
        Position = self.Frame.Position + UDim2.fromOffset(10, 10)
    }, 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
    task.delay(0.2, function()
        self.ScreenGui:Destroy()
    end)
end
function Window:_setActiveTab(tab)
    if self.ActiveTab then self.ActiveTab:Hide() end
    self.ActiveTab = tab
    tab:Show()
    for _, otherTab in ipairs(self.Tabs) do
        local isActive = (otherTab == tab)
        TweenUtil.play(otherTab.Button, {
            BackgroundColor3 = isActive and Theme.Accent or Theme.Surface,
            TextColor3 = isActive and Theme.Text or Theme.Muted,
        })
    end
end
function Window:AddTab(options)
    local tab = Tab.new(self, options)
    table.insert(self.Tabs, tab)
    if not self.ActiveTab then self:_setActiveTab(tab) end
    tab.Button.MouseButton1Click:Connect(function()
        self:_setActiveTab(tab)
    end)
    return tab
end

-- Notifications ---------------------------------------------------------------
local Notify = {}
local notifyContainer
local activeNotifications = {}

local function getNotifyContainer()
    if notifyContainer and notifyContainer.Parent then return notifyContainer end
    local playerGui = Players.LocalPlayer:WaitForChild("PlayerGui")
    notifyContainer = Create.new("ScreenGui", {
        Name = "NovaNotifications",
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        Parent = playerGui,
    })
    Create.new("Frame", {
        Name = "Stack",
        Parent = notifyContainer,
        BackgroundTransparency = 1,
        Position = UDim2.new(1, -Theme.Padding, 0, Theme.Padding),
        Size = UDim2.fromOffset(330, 0),
        AnchorPoint = Vector2.new(1, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        ListLayout = { Padding = 10, HorizontalAlignment = Enum.HorizontalAlignment.Right },
    })
    return notifyContainer
end

local function repositionNotifications()
    for i, item in ipairs(activeNotifications) do
        item.Frame.LayoutOrder = i
    end
end

function Notify.show(options)
    options = options or {}
    local gui = getNotifyContainer()
    local stack = gui:FindFirstChild("Stack")
    local duration = options.Duration or 4

    if #activeNotifications >= (Theme.NotificationMax or 5) then
        local oldest = table.remove(activeNotifications, 1)
        oldest.Frame:Destroy()
    end

    local frame = Create.new("Frame", {
        Name = "Notification",
        Parent = stack,
        BackgroundColor3 = Theme.Surface,
        BorderSizePixel = 0,
        Size = UDim2.fromOffset(310, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        CornerRadius = Theme.CornerRadius,
        Stroke = { Color = Theme.Accent, Thickness = 1.5 },
    })

    local title = Create.new("TextLabel", {
        Name = "Title",
        Parent = frame,
        BackgroundTransparency = 1,
        Font = Theme.FontBold,
        Text = options.Title or "Notice",
        TextColor3 = Theme.Text,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left,
        Size = UDim2.new(1, -Theme.Padding*2, 0, 20),
        Position = UDim2.fromOffset(Theme.Padding, Theme.Padding),
    })

    local content = Create.new("TextLabel", {
        Name = "Content",
        Parent = frame,
        BackgroundTransparency = 1,
        Font = Theme.Font,
        Text = options.Content or "",
        TextColor3 = Theme.Muted,
        TextSize = 13,
        TextWrapped = true,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Top,
        Size = UDim2.new(1, -Theme.Padding*2, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        Position = UDim2.fromOffset(Theme.Padding, Theme.Padding + 24),
    })

    local progressTrack = Create.new("Frame", {
        Name = "ProgressTrack",
        Parent = frame,
        BackgroundColor3 = Theme.Background,
        BorderSizePixel = 0,
        Size = UDim2.new(1, -Theme.Padding*2, 0, 4),
        Position = UDim2.new(0, Theme.Padding, 1, -(Theme.Padding + 4)),
        CornerRadius = UDim.new(1, 0),
    })
    local progressFill = Create.new("Frame", {
        Name = "ProgressFill",
        Parent = progressTrack,
        BackgroundColor3 = Theme.Accent,
        BorderSizePixel = 0,
        Size = UDim2.fromScale(1, 1),
        CornerRadius = UDim.new(1, 0),
    })

    local closeBtn = Create.new("TextButton", {
        Name = "CloseBtn",
        Parent = frame,
        BackgroundTransparency = 1,
        Font = Theme.FontBold,
        Text = "×",
        TextColor3 = Theme.Muted,
        TextSize = 18,
        Size = UDim2.fromOffset(22, 22),
        Position = UDim2.new(1, -28, 0, 4),
        ZIndex = 2,
    })
    closeBtn.MouseButton1Click:Connect(function()
        frame:Destroy()
        for i, item in ipairs(activeNotifications) do
            if item.Frame == frame then
                table.remove(activeNotifications, i)
                break
            end
        end
        repositionNotifications()
    end)

    local bottomPad = Instance.new("UIPadding")
    bottomPad.PaddingBottom = UDim.new(0, Theme.Padding + 10)
    bottomPad.Parent = frame

    local item = { Frame = frame }
    table.insert(activeNotifications, item)
    repositionNotifications()

    -- Animación de entrada
    frame.BackgroundTransparency = 1
    title.TextTransparency = 1
    content.TextTransparency = 1
    frame.Position = UDim2.new(1, 20, 0, frame.Position.Y.Offset)
    TweenUtil.play(frame, { Position = UDim2.new(1, 0, 0, frame.Position.Y.Offset), BackgroundTransparency = 0 })
    TweenUtil.play(title, { TextTransparency = 0 })
    TweenUtil.play(content, { TextTransparency = 0 })

    if duration > 0 then
        TweenUtil.play(progressFill, { Size = UDim2.fromScale(0, 1) }, duration, Enum.EasingStyle.Linear)
        task.delay(duration, function()
            if not frame.Parent then return end
            TweenUtil.play(frame, { BackgroundTransparency = 1 }, 0.2)
            TweenUtil.play(title, { TextTransparency = 1 })
            TweenUtil.play(content, { TextTransparency = 1 })
            task.delay(0.2, function()
                if frame.Parent then frame:Destroy() end
                for i, item in ipairs(activeNotifications) do
                    if item.Frame == frame then
                        table.remove(activeNotifications, i)
                        break
                    end
                end
                repositionNotifications()
            end)
        end)
    end

    return {
        Destroy = function() if frame.Parent then frame:Destroy() end end,
        SetTitle = function(t) title.Text = t end,
        SetContent = function(c) content.Text = c end,
    }
end

