-- Button ----------------------------------------------------------------------

local Button = {}
Button.__index = Button

local STYLE_COLORS = {
	Default = Theme.Surface,
	Primary = Theme.Accent,
	Danger = Theme.Danger,
}

local STYLE_HOVER = {
	Default = Theme.SurfaceHover,
	Primary = Theme.AccentDark,
	Danger = Color3.fromRGB(180, 40, 40),
}

function Button.new(parent, options)
	options = options or {}

	local self = setmetatable({}, Button)
	local style = options.Style or "Default"
	local baseColor = STYLE_COLORS[style] or STYLE_COLORS.Default
	local hoverColor = STYLE_HOVER[style] or STYLE_HOVER.Default

	self.Frame = Create.new("Frame", {
		Name = "ButtonRow",
		Parent = parent,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, Theme.ItemHeight),
	})

	self.Button = Create.new("TextButton", {
		Name = options.Name or "Button",
		Parent = self.Frame,
		BackgroundColor3 = baseColor,
		AutoButtonColor = false,
		Font = Theme.FontBold,
		Text = options.Name or "Button",
		TextColor3 = Theme.Text,
		TextSize = 13,
		Size = UDim2.fromScale(1, 1),
		CornerRadius = UDim.new(0, 4),
	})

	TweenUtil.bindHover(self.Button, baseColor, hoverColor)

	self.Button.MouseButton1Click:Connect(function()
		if options.Callback then
			options.Callback()
		end
	end)

	return self
