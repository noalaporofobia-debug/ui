		Font = Theme.Font,
		Text = options.Name or "Tab",
		TextColor3 = Theme.Muted,
		TextSize = 13,
		Size = UDim2.fromOffset(90, Theme.TabBarHeight - 8),
		CornerRadius = UDim.new(0, 4),
	})

	self.Page = Create.new("ScrollingFrame", {
		Name = (options.Name or "Tab") .. "Page",
		Parent = window.ContentArea,
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.fromScale(1, 1),
		CanvasSize = UDim2.new(0, 0, 0, 0),
		ScrollBarThickness = 4,
		ScrollBarImageColor3 = Theme.Accent,
		ClipsDescendants = false,
		Visible = false,
	})

	self.Content = Create.new("Frame", {
		Name = "Content",
		Parent = self.Page,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		ListLayout = { Padding = Theme.Padding },
		Padding = {
			PaddingLeft = Theme.Padding,
			PaddingRight = Theme.Padding,
			PaddingTop = Theme.Padding,
			PaddingBottom = Theme.Padding,
		},
	})

	local layout = self.Content:FindFirstChildOfClass("UIListLayout")
	layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		self.Page.CanvasSize = UDim2.fromOffset(0, layout.AbsoluteContentSize.Y + Theme.Padding * 2)
	end)

	return self
end

function Tab:Show()
	self.Visible = true
	self.Page.Visible = true
end

function Tab:Hide()
	self.Visible = false
	self.Page.Visible = false
end

function Tab:AddSection(options)
	local section = Section.new(self, options)
	table.insert(self.Sections, section)
	return section
end

-- Window ----------------------------------------------------------------------

local Window = {}
Window.__index = Window

function Window.new(options)
	options = options or {}

	local self = setmetatable({}, Window)
	self.Tabs = {}
	self.ActiveTab = nil

	local playerGui = Players.LocalPlayer:WaitForChild("PlayerGui")
	local windowName = options.Name or "UIWindow"
	local windowTitle = options.Title or windowName
	local windowSize = options.Size or UDim2.fromOffset(420, 540)
	local windowPosition = options.Position or UDim2.new(0.297, 0, 0.112, 0)

	self.ScreenGui = Create.new("ScreenGui", {
		Name = windowName,
		ResetOnSpawn = false,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
		Parent = playerGui,
	})

	self.Frame = Create.new("Frame", {
		Name = "Main",
		Parent = self.ScreenGui,
		BackgroundColor3 = Theme.Background,
		BorderSizePixel = 0,
		Size = windowSize,
		Position = windowPosition,
		Active = true,
		ClipsDescendants = true,
		CornerRadius = Theme.CornerRadius,
		Stroke = { Color = Theme.Border, Thickness = 1 },
	})

	self.TitleBar = Create.new("Frame", {
		Name = "TitleBar",
		Parent = self.Frame,
		BackgroundColor3 = Theme.Surface,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, Theme.TitleBarHeight),
	})

	self.TitleLabel = Create.new("TextLabel", {
		Name = "Title",
		Parent = self.TitleBar,
		BackgroundTransparency = 1,
		Font = Theme.FontBold,
		Text = windowTitle,
		TextColor3 = Theme.Text,
		TextSize = 14,
		TextXAlignment = Enum.TextXAlignment.Left,
		Position = UDim2.fromOffset(Theme.Padding, 0),
		Size = UDim2.new(1, -(Theme.TitleBarHeight + Theme.Padding * 2), 1, 0),
	})

	self.CloseButton = Create.new("TextButton", {
		Name = "Close",
		Parent = self.TitleBar,
		BackgroundColor3 = Theme.Surface,
		AutoButtonColor = false,
		Font = Theme.FontBold,
		Text = "X",
		TextColor3 = Theme.Muted,
		TextSize = 14,
		Size = UDim2.fromOffset(Theme.TitleBarHeight, Theme.TitleBarHeight),
		Position = UDim2.new(1, -Theme.TitleBarHeight, 0, 0),
	})

	self.TabBar = Create.new("Frame", {
		Name = "TabBar",
		Parent = self.Frame,
		BackgroundColor3 = Theme.Background,
		BorderSizePixel = 0,
		Position = UDim2.fromOffset(0, Theme.TitleBarHeight),
		Size = UDim2.new(1, 0, 0, Theme.TabBarHeight),
		ListLayout = {
			FillDirection = Enum.FillDirection.Horizontal,
			Padding = 4,
			HorizontalAlignment = Enum.HorizontalAlignment.Left,
		},
		Padding = {
			PaddingLeft = Theme.Padding,
			PaddingRight = Theme.Padding,
			PaddingTop = 4,
			PaddingBottom = 4,
		},
	})

	self.ContentArea = Create.new("Frame", {
		Name = "ContentArea",
		Parent = self.Frame,
		BackgroundTransparency = 1,
		Position = UDim2.fromOffset(0, Theme.TitleBarHeight + Theme.TabBarHeight),
		Size = UDim2.new(1, 0, 1, -(Theme.TitleBarHeight + Theme.TabBarHeight)),
	})

	Drag.enable(self.TitleBar, self.Frame)

	self.CloseButton.MouseEnter:Connect(function()
		TweenUtil.play(self.CloseButton, { TextColor3 = Theme.Danger })
	end)

	self.CloseButton.MouseLeave:Connect(function()
		TweenUtil.play(self.CloseButton, { TextColor3 = Theme.Muted })
	end)

	self.CloseButton.MouseButton1Click:Connect(function()
		self:Destroy()
	end)

	return self
end

function Window:SetTitle(title)
	self.TitleLabel.Text = title
end

function Window:Toggle(visible)
	if visible == nil then
		self.ScreenGui.Enabled = not self.ScreenGui.Enabled
	else
		self.ScreenGui.Enabled = visible
	end
end

function Window:Destroy()
	self.ScreenGui:Destroy()
end

function Window:_setActiveTab(tab)
	if self.ActiveTab then
		self.ActiveTab:Hide()
	end

	self.ActiveTab = tab
	tab:Show()

	for _, otherTab in ipairs(self.Tabs) do
		local isActive = otherTab == tab
		TweenUtil.play(otherTab.Button, {
			BackgroundColor3 = isActive and Theme.Accent or Theme.Surface,
			TextColor3 = isActive and Theme.Text or Theme.Muted,
		})
	end
end

function Window:AddTab(options)
	local tab = Tab.new(self, options)
	table.insert(self.Tabs, tab)

	if not self.ActiveTab then
		self:_setActiveTab(tab)
	end

	tab.Button.MouseButton1Click:Connect(function()
		self:_setActiveTab(tab)
	end)

	return tab
end

-- Notify ----------------------------------------------------------------------

local Notify = {}

local notifyContainer
local activeNotifications = {}

local function getNotifyContainer()
	if notifyContainer and notifyContainer.Parent then
		return notifyContainer
	end

	local playerGui = Players.LocalPlayer:WaitForChild("PlayerGui")

	notifyContainer = Create.new("ScreenGui", {
		Name = "UINotifications",
		ResetOnSpawn = false,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
		Parent = playerGui,
	})

	Create.new("Frame", {
		Name = "Stack",
		Parent = notifyContainer,
		BackgroundTransparency = 1,
		Position = UDim2.new(1, -Theme.Padding, 0, Theme.Padding),
		Size = UDim2.fromOffset(320, 0),
		AnchorPoint = Vector2.new(1, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		ListLayout = {
			Padding = 8,
			HorizontalAlignment = Enum.HorizontalAlignment.Right,
		},
	})

	return notifyContainer
end

local function repositionNotifications()
	for index, item in ipairs(activeNotifications) do
		item.Frame.LayoutOrder = index
	end
end

function Notify.show(options)
	options = options or {}

	local gui = getNotifyContainer()
	local stack = gui:FindFirstChild("Stack")
	local duration = options.Duration or 4

	local frame = Create.new("Frame", {
		Name = "Notification",
		Parent = stack,
		BackgroundColor3 = Theme.Surface,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(300, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		CornerRadius = Theme.CornerRadius,
		Stroke = { Color = Theme.Accent, Thickness = 1 },
	})

	local title = Create.new("TextLabel", {
		Name = "Title",
		Parent = frame,
		BackgroundTransparency = 1,
		Font = Theme.FontBold,
		Text = options.Title or "Notice",
		TextColor3 = Theme.Text,
		TextSize = 14,
		TextXAlignment = Enum.TextXAlignment.Left,
		Size = UDim2.new(1, -Theme.Padding * 2, 0, 20),
		Position = UDim2.fromOffset(Theme.Padding, Theme.Padding),
	})

	local content = Create.new("TextLabel", {
		Name = "Content",
		Parent = frame,
		BackgroundTransparency = 1,
		Font = Theme.Font,
		Text = options.Content or "",
		TextColor3 = Theme.Muted,
		TextSize = 13,
		TextWrapped = true,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextYAlignment = Enum.TextYAlignment.Top,
		Size = UDim2.new(1, -Theme.Padding * 2, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		Position = UDim2.fromOffset(Theme.Padding, Theme.Padding + 22),
	})

	local progressTrack = Create.new("Frame", {
		Name = "ProgressTrack",
		Parent = frame,
		BackgroundColor3 = Theme.Background,
		BorderSizePixel = 0,
		Size = UDim2.new(1, -Theme.Padding * 2, 0, 3),
		Position = UDim2.new(0, Theme.Padding, 1, -(Theme.Padding + 3)),
		CornerRadius = UDim.new(1, 0),
	})

	local progressFill = Create.new("Frame", {
		Name = "ProgressFill",
		Parent = progressTrack,
		BackgroundColor3 = Theme.Accent,
		BorderSizePixel = 0,
		Size = UDim2.fromScale(1, 1),
		CornerRadius = UDim.new(1, 0),
	})

	local bottomPadding = Instance.new("UIPadding")
	bottomPadding.PaddingBottom = UDim.new(0, Theme.Padding + 8)
	bottomPadding.Parent = frame

	local item = { Frame = frame }

	table.insert(activeNotifications, item)
	repositionNotifications()

	frame.BackgroundTransparency = 1
	title.TextTransparency = 1
	content.TextTransparency = 1

	TweenUtil.play(frame, { BackgroundTransparency = 0 }, 0.2)
	TweenUtil.play(title, { TextTransparency = 0 }, 0.2)
	TweenUtil.play(content, { TextTransparency = 0 }, 0.2)

	if duration > 0 then
		TweenUtil.play(progressFill, { Size = UDim2.fromScale(0, 1) }, duration, Enum.EasingStyle.Linear)

		task.delay(duration, function()
			if not frame.Parent then
				return
			end

			local fade = TweenUtil.play(frame, { BackgroundTransparency = 1 }, 0.2)
			TweenUtil.play(title, { TextTransparency = 1 }, 0.2)
			TweenUtil.play(content, { TextTransparency = 1 }, 0.2)

			fade.Completed:Wait()
			frame:Destroy()

			for index, activeItem in ipairs(activeNotifications) do
				if activeItem == item then
					table.remove(activeNotifications, index)
					break
				end
			end

			repositionNotifications()
		end)
	end

	return {
		Destroy = function()
			if frame.Parent then
				frame:Destroy()
			end
		end,
		SetTitle = function(text)
			title.Text = text
		end,
		SetContent = function(text)
			content.Text = text
		end,
	}
end

