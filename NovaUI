-- Theme -----------------------------------------------------------------------
local Theme = {
	Background = Color3.fromRGB(25, 25, 25),
	Surface = Color3.fromRGB(35, 35, 35),
	SurfaceHover = Color3.fromRGB(45, 45, 45),
	Accent = Color3.fromRGB(0, 170, 255),
	AccentDark = Color3.fromRGB(0, 130, 200),
	Text = Color3.fromRGB(255, 255, 255),
	Muted = Color3.fromRGB(180, 180, 180),
	Border = Color3.fromRGB(255, 255, 255),
	Danger = Color3.fromRGB(220, 60, 60),
	CornerRadius = UDim.new(0, 6),
	Font = Enum.Font.Gotham,
	FontBold = Enum.Font.GothamBold,
	Padding = 8,
	ItemHeight = 36,
	TitleBarHeight = 32,
	TabBarHeight = 36,
	SectionHeaderHeight = 28,
	ScrollbarThickness = 4,
	SnapDistance = 80,
	NotificationMax = 5,
	AnimationDuration = 0.15,
}

local function applyTheme(overrides)
	if not overrides then return end
	for k, v in pairs(overrides) do
		Theme[k] = v
	end
end

-- Create ----------------------------------------------------------------------
local Create = {}
function Create.new(className, props)
	local instance = Instance.new(className)
	for key, value in pairs(props or {}) do
		if key == "CornerRadius" then
			local corner = Instance.new("UICorner")
			corner.CornerRadius = value
			corner.Parent = instance
		elseif key == "Stroke" then
			local stroke = Instance.new("UIStroke")
			stroke.Color = value.Color or Theme.Border
			stroke.Thickness = value.Thickness or 1
			stroke.Transparency = value.Transparency or 0
			stroke.ApplyStrokeMode = value.ApplyStrokeMode or Enum.ApplyStrokeMode.Border
			stroke.Parent = instance
		elseif key == "Padding" then
			local pad = Instance.new("UIPadding")
			for side, amount in pairs(value) do
				pad[side] = UDim.new(0, amount)
			end
			pad.Parent = instance
		elseif key == "ListLayout" then
			local layout = Instance.new("UIListLayout")
			layout.SortOrder = Enum.SortOrder.LayoutOrder
			layout.Padding = UDim.new(0, value.Padding or Theme.Padding)
			layout.FillDirection = value.FillDirection or Enum.FillDirection.Vertical
			layout.HorizontalAlignment = value.HorizontalAlignment or Enum.HorizontalAlignment.Left
			layout.VerticalAlignment = value.VerticalAlignment or Enum.VerticalAlignment.Top
			layout.Parent = instance
		else
			instance[key] = value
		end
	end
	return instance
end

-- Drag ------------------------------------------------------------------------
local Drag = {}
function Drag.enable(handle, target, snap)
	local dragging, dragStart, startPos
	local guiInset = 0

	handle.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = target.Position

			-- Prevent text selection
			UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragStart
			local x = startPos.X.Offset + delta.X
			local y = startPos.Y.Offset + delta.Y

			-- Keep within screen bounds
			local screenSize = workspace.CurrentCamera.ViewportSize
			local width = target.AbsoluteSize.X
			local height = target.AbsoluteSize.Y

			x = math.clamp(x, 0, screenSize.X - width)
			y = math.clamp(y, 0, screenSize.Y - height)

			target.Position = UDim2.new(0, x, 0, y)
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
			dragging = false
			UserInputService.MouseBehavior = Enum.MouseBehavior.Default

			-- Snap to edges if close
			if snap then
				local screenSize = workspace.CurrentCamera.ViewportSize
				local pos = target.Position
				local x, y = pos.X.Offset, pos.Y.Offset
				local w, h = target.AbsoluteSize.X, target.AbsoluteSize.Y
				local snapX, snapY = x, y

				if x < Theme.SnapDistance then snapX = 0
				elseif x + w > screenSize.X - Theme.SnapDistance then snapX = screenSize.X - w end

				if y < Theme.SnapDistance then snapY = 0
				elseif y + h > screenSize.Y - Theme.SnapDistance then snapY = screenSize.Y - h end

				if snapX ~= x or snapY ~= y then
					TweenUtil.play(target, { Position = UDim2.new(0, snapX, 0, snapY) }, 0.2)
				end
			end
		end
	end)
end

-- Tween -----------------------------------------------------------------------
local TweenUtil = {}
function TweenUtil.play(instance, props, duration, style, direction)
	local info = TweenInfo.new(
		duration or Theme.AnimationDuration,
		style or Enum.EasingStyle.Quad,
		direction or Enum.EasingDirection.Out
	)
	local tween = TweenService:Create(instance, info, props)
	tween:Play()
	return tween
end

function TweenUtil.bindHover(button, normal, hover)
	button.MouseEnter:Connect(function()
		TweenUtil.play(button, { BackgroundColor3 = hover, TextColor3 = Theme.Text })
	end)
	button.MouseLeave:Connect(function()
		TweenUtil.play(button, { BackgroundColor3 = normal, TextColor3 = Theme.Muted })
	end)
end

-- Tooltip ---------------------------------------------------------------------
local Tooltip = {}
function Tooltip.attach(gui, text)
	local tooltip
	gui.MouseEnter:Connect(function()
		if tooltip then tooltip:Destroy() end
		tooltip = Create.new("Frame", {
			Parent = gui,
			BackgroundColor3 = Theme.Background,
			BorderSizePixel = 0,
			Size = UDim2.new(0, 0, 0, 0),
			AutomaticSize = Enum.AutomaticSize.XY,
			Position = UDim2.new(1, 8, 0, 0),
			CornerRadius = UDim.new(0, 4),
			Stroke = { Color = Theme.Border, Thickness = 1 },
			ZIndex = 100,
		})
		local label = Create.new("TextLabel", {
			Parent = tooltip,
			BackgroundTransparency = 1,
			Font = Theme.Font,
			Text = text,
			TextColor3 = Theme.Text,
			TextSize = 12,
			TextXAlignment = Enum.TextXAlignment.Left,
			Size = UDim2.new(0, 0, 0, 0),
			AutomaticSize = Enum.AutomaticSize.XY,
			Padding = { PaddingLeft = 6, PaddingRight = 6, PaddingTop = 4, PaddingBottom = 4 },
		})
		tooltip.BackgroundTransparency = 1
		TweenUtil.play(tooltip, { BackgroundTransparency = 0 })
	end)
	gui.MouseLeave:Connect(function()
		if tooltip then
			TweenUtil.play(tooltip, { BackgroundTransparency = 1 })
			task.delay(0.15, function()
				if tooltip then tooltip:Destroy() end
			end)
		end
	end)
end

-- Save/Load -------------------------------------------------------------------
local Config = {}
Config.FileName = "UILibConfig.json"

function Config.Save(windowName, data)
	local config = {}
	pcall(function()
		local existing = HttpService:JSONDecode(readfile and readfile(Config.FileName) or "{}")
		config = existing
	end)
	config[windowName] = data
	pcall(function()
		if writefile then writefile(Config.FileName, HttpService:JSONEncode(config)) end
	end)
end

function Config.Load(windowName)
	local success, content = pcall(function()
		return readfile and readfile(Config.FileName)
	end)
	if not success or not content then return nil end
	local config = HttpService:JSONDecode(content)
	return config and config[windowName]
end

