local Toggle = {}
function Toggle:Create(parent, opts)
    local f = Create("Frame", {Parent=parent, BackgroundTransparency=1, Size=UDim2.new(1,0,0,Theme.ItemHeight)})
    local name = Create("TextLabel", {Parent=f, BackgroundTransparency=1, Font=Theme.Font, Text=opts.Text or L"Toggle", TextColor3=Theme.Text, TextSize=14, TextXAlignment=Enum.TextXAlignment.Left, Size=UDim2.new(1,-54,1,0)})
    local track = Create("TextButton", {Parent=f, BackgroundColor3=Theme.Surface, AutoButtonColor=false, Text="", Size=UDim2.fromOffset(44,24), Position=UDim2.new(1,-44,0.5,-12), Corner=UDim.new(1,0)})
    local knob = Create("Frame", {Parent=track, BackgroundColor3=Color3.new(1,1,1), Size=UDim2.fromOffset(18,18), Position=UDim2.new(0,2,0.5,-9), Corner=UDim.new(1,0)})
    if opts.Tooltip then Tooltip.attach(name, opts.Tooltip) end
    local val = opts.Default or false
    local function update()
        local goal = val and Theme.Accent or Theme.Surface
        local pos = val and UDim2.new(1,-20,0.5,-9) or UDim2.new(0,2,0.5,-9)
        Spring(track, {BackgroundColor3=goal}, 0.2, 0.8, 0.6)
        Spring(knob, {Position=pos}, 0.2, 0.8, 0.6)
    end
    track.MouseButton1Click:Connect(function()
        PlaySound(); val = not val; update(); if opts.Callback then opts.Callback(val) end; scheduleAutosave()
    end)
    track.MouseButton2Click:Connect(function()
        ContextMenu.show(track, {{Text=L"Reset", Callback=function() val=false; update(); if opts.Callback then opts.Callback(false) end; scheduleAutosave() end}})
    end)
    if val then update() end
    local c = { Frame = f, GetValue = function() return val end, SetValue = function(v) val=v; update(); scheduleAutosave() end, Destroy = function() f:Destroy() end, Options = opts }
    local base = ComponentBase.new(c, "Toggle", opts.WindowTitle, opts.TabName, opts.SectionName, opts.Name or opts.Text)
    withAutosave(c.SetValue, c)
    return base
end

