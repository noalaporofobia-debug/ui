local Slider = {}
Slider.__index = Slider
local function clamp(v, min, max) return math.max(min, math.min(max, v)) end
local function roundToIncrement(v, inc)
    if inc <= 0 then return v end
    return math.floor(v / inc + 0.5) * inc
end
function Slider.new(parent, options)
    local self = setmetatable({}, Slider)
    self.Min = options.Min or 0
    self.Max = options.Max or 100
    self.Increment = options.Increment or 1
    self.Value = clamp(roundToIncrement(options.Default or self.Min, self.Increment), self.Min, self.Max)
    self.Callback = options.Callback
    self.Dragging = false

    self.Frame = Create.new("Frame", {
        Name = "SliderRow",
        Parent = parent,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, Theme.ItemHeight + 10),
    })
    self.NameLabel = Create.new("TextLabel", {
        Name = "Name",
        Parent = self.Frame,
        BackgroundTransparency = 1,
        Font = Theme.Font,
        Text = options.Name or "Slider",
        TextColor3 = Theme.Text,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left,
        Size = UDim2.new(1, -52, 0, 20),
    })
    self.ValueLabel = Create.new("TextLabel", {
        Name = "Value",
        Parent = self.Frame,
        BackgroundTransparency = 1,
        Font = Theme.FontBold,
        Text = tostring(self.Value),
        TextColor3 = Theme.Accent,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Right,
        Size = UDim2.new(0, 50, 0, 20),
        Position = UDim2.new(1, -50, 0, 0),
    })
    self.Track = Create.new("Frame", {
        Name = "Track",
        Parent = self.Frame,
        BackgroundColor3 = Theme.Surface,
        BorderSizePixel = 0,
        Position = UDim2.fromOffset(0, 26),
        Size = UDim2.new(1, 0, 0, 10),
        CornerRadius = UDim.new(1, 0),
    })
    self.Fill = Create.new("Frame", {
        Name = "Fill",
        Parent = self.Track,
        BackgroundColor3 = Theme.Accent,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 0, 1, 0),
        CornerRadius = UDim.new(1, 0),
    })
    self.Knob = Create.new("TextButton", {
        Name = "Knob",
        Parent = self.Track,
        BackgroundColor3 = Theme.Text,
        AutoButtonColor = false,
        Text = "",
        Size = UDim2.fromOffset(16, 16),
        Position = UDim2.new(0, -8, 0.5, -8),
        CornerRadius = UDim.new(1, 0),
    })
    self:_updateVisuals(false)

    local function startDrag(input)
        self.Dragging = true
        self:_setFromInput(input)
    end
    self.Knob.InputBegan:Connect(startDrag)
    self.Track.InputBegan:Connect(startDrag)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            self.Dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if self.Dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            self:_setFromInput(input)
        end
    end)
    return self
end
function Slider:_ratio()
    if self.Max == self.Min then return 0 end
    return (self.Value - self.Min) / (self.Max - self.Min)
end
function Slider:_updateVisuals(animate)
    local ratio = self:_ratio()
    self.ValueLabel.Text = tostring(self.Value)
    local fillSize = UDim2.new(ratio, 0, 1, 0)
    local knobPos = UDim2.new(ratio, -8, 0.5, -8)
    if animate then
        TweenUtil.play(self.Fill, { Size = fillSize })
        TweenUtil.play(self.Knob, { Position = knobPos })
    else
        self.Fill.Size = fillSize
        self.Knob.Position = knobPos
    end
end
function Slider:_setFromInput(input)
    local track = self.Track
    local relative = (input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X
    relative = clamp(relative, 0, 1)
    local raw = self.Min + (self.Max - self.Min) * relative
    self:SetValue(raw)
end
function Slider:SetValue(value)
    local newVal = clamp(roundToIncrement(value, self.Increment), self.Min, self.Max)
    if newVal == self.Value then
        self:_updateVisuals(true)
        return
    end
    self.Value = newVal
    self:_updateVisuals(true)
    if self.Callback then self.Callback(self.Value) end
end
function Slider:GetValue() return self.Value end
function Slider:Destroy() self.Frame:Destroy() end

