    local f = Create("Frame", {Parent=parent, BackgroundTransparency=1, Size=UDim2.new(1,0,0,0), AutomaticSize=Enum.AutomaticSize.Y})
    local name = Create("TextLabel", {Parent=f, BackgroundTransparency=1, Font=Theme.Font, Text=opts.Text or L"List", TextColor3=Theme.Text, TextSize=14, TextXAlignment=Enum.TextXAlignment.Left, Size=UDim2.new(1,0,0,20)})
    local listFrame = Create("ScrollingFrame", {Parent=f, BackgroundColor3=Theme.Surface, BorderSizePixel=0, Size=UDim2.new(1,0,0,math.min(#opts.Options*32+8,160)), Position=UDim2.fromOffset(0,24), Corner=Theme.Radius, CanvasSize=UDim2.new(0,0,0,#opts.Options*32+8), ScrollBarThickness=4, ScrollBarImageColor3=Theme.Accent})
    local content = Create("Frame", {Parent=listFrame, BackgroundTransparency=1, Size=UDim2.new(1,0,0,0), AutomaticSize=Enum.AutomaticSize.Y, List={Padding=2}, Padding={PaddingTop=4,PaddingBottom=4,PaddingLeft=4,PaddingRight=4}})
    local selected = {}
    local buttons = {}
    local function updateVisuals(option)
        if buttons[option] then
            local active = selected[option] and true or false
            buttons[option].BackgroundColor3 = active and Theme.Accent or Theme.Surface
            buttons[option].TextColor3 = active and Color3.new(1,1,1) or Theme.Text
        end
    end
    local function toggle(option)
        selected[option] = not selected[option]
        updateVisuals(option)
        if opts.Callback then opts.Callback(selected) end; scheduleAutosave()
    end
    for _, option in ipairs(opts.Options or {}) do
        local row = Create("TextButton", {Parent=content, BackgroundColor3=Theme.Surface, AutoButtonColor=false, Font=Theme.Font, Text=option, TextColor3=Theme.Text, TextSize=13, Size=UDim2.new(1,0,0,30), Corner=UDim.new(0,4)})
        row.MouseButton1Click:Connect(function() toggle(option) end)
        row.MouseEnter:Connect(function() if not selected[option] then TweenObj(row,{BackgroundColor3=Theme.SurfaceAlt}) end end)
        row.MouseLeave:Connect(function() if not selected[option] then TweenObj(row,{BackgroundColor3=Theme.Surface}) end end)
        buttons[option] = row
    end
    -- Restore default selections
    if opts.Default then
        for _, opt in ipairs(opts.Default) do
            selected[opt] = true; updateVisuals(opt)
        end
    end
    local c = { Frame = f, GetSelected = function() return selected end, SetSelected = function(v) selected = {}; for _,opt in ipairs(v) do selected[opt]=true; updateVisuals(opt) end; if opts.Callback then opts.Callback(selected) end; scheduleAutosave() end, Destroy = function() f:Destroy() end, Options = opts }
    return ComponentBase.new(c, "List", opts.WindowTitle, opts.TabName, opts.SectionName, opts.Name or opts.Text)
end

